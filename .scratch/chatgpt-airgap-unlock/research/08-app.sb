(version 1)

; THROWAWAY PROTOTYPE ONLY. The copied app owns its CDP listener and may reach
; only the separately-owned loopback proxy.
(allow default)
(deny network-outbound (remote ip))
(deny network-inbound (local ip))
(allow network-outbound (remote ip "localhost:49309"))
(allow network-inbound (local ip "localhost:49308"))

(deny file-read* (subpath (param "REAL_HOME")))
(deny file-write* (subpath (param "REAL_HOME")))
(deny file-write* (subpath "/Applications/ChatGPT.app"))
(deny file-write* (literal (param "NATIVE_GUI_PROBE_BIN")))
(deny mach-lookup (regex #"^com\\.apple\\.securityd"))
