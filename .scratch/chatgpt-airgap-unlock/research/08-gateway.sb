(version 1)

; THROWAWAY PROTOTYPE ONLY. The immutable gateway accepts requests only on its
; assigned loopback port and forwards only to the assigned upstream observer.
(allow default)
(deny network-outbound (remote ip))
(deny network-inbound (local ip))
(allow network-outbound (remote ip (string-append "localhost:" (param "UPSTREAM_OBSERVER_PORT"))))
(allow network-inbound (local ip (string-append "localhost:" (param "GATEWAY_PORT"))))

; The gateway is materialized under the disposable run root and needs no
; operator-home access.
(deny file-read* (subpath (param "REAL_HOME")))
(deny file-write* (subpath (param "REAL_HOME")))
(deny file-write* (subpath "/Applications/ChatGPT.app"))
