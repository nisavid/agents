(version 1)

; THROWAWAY PROTOTYPE ONLY. The bundled host has no listener and may use only
; the observer proxy and the direct OptiQ provider.
(allow default)
(deny network-outbound (remote ip))
(deny network-inbound (local ip))
(allow network-outbound (remote ip (string-append "localhost:" (param "PROXY_PORT"))))
(allow network-outbound (remote ip (string-append "localhost:" (param "OPTIQ_PORT"))))

(deny file-read* (subpath (param "REAL_HOME")))
(deny file-write* (subpath (param "REAL_HOME")))
(deny file-write* (literal (param "NATIVE_GUI_PROBE_BIN")))
