(version 1)

; THROWAWAY PROTOTYPE ONLY. Bundled-Codex metadata probes receive a fresh
; run-local HOME/CODEX_HOME environment and has no network role.
(allow default)
(deny network-outbound)
(deny network-inbound)
(deny file-read* (subpath (param "REAL_HOME")))
(deny file-write* (subpath (param "REAL_HOME")))
(deny file-write* (subpath "/Applications/ChatGPT.app"))
