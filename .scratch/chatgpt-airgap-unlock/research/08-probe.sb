(version 1)

; THROWAWAY PROTOTYPE ONLY. The target is a separately named app copy in /private/tmp.
(allow default)

; The provider, proxy observer, and CDP observer are loopback-only. Deny every
; connection to a remote IP while permitting those three local seams.
(deny network-outbound (remote ip))
(deny network-inbound (local ip))
(allow network-outbound (remote ip "localhost:*"))
(allow network-inbound (local ip "localhost:*"))

; Do not let the disposable process tree consult the operator's home or login
; keychain services.
(deny file-read* (subpath (param "REAL_HOME")))
(deny file-write* (subpath (param "REAL_HOME")))
(deny file-write* (subpath "/Applications/ChatGPT.app"))
(deny mach-lookup (regex #"^com\\.apple\\.securityd"))
