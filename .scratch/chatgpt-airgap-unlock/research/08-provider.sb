(version 1)

; THROWAWAY PROTOTYPE ONLY. Seatbelt receives the provider listener port from
; the validated runner. The OptiQ argv separately fixes its host to 127.0.0.1.
(allow default)
(deny network-outbound (remote ip))
(deny network-inbound (local ip))
(allow network-inbound (local ip (string-append "*:" (param "OPTIQ_PORT"))))

; The provider is limited to its pinned runtime and model, plus its three
; disposable writable directories. Other operator-home and run-root state is
; explicitly unavailable. These non-overlapping rules leave the pinned model
; and runtime readable while retaining macOS framework and Metal reads.
(deny file-read-data
  (require-all
    (subpath (param "REAL_HOME"))
    (require-not (subpath (param "MODEL_REPO")))
    (require-not (subpath (param "OPTIQ_RUNTIME")))))
(deny file-read-data
  (require-all
    (subpath (param "RUN_ROOT"))
    (require-not (subpath (param "PROVIDER_HOME")))
    (require-not (subpath (param "PROVIDER_TMP")))
    (require-not (subpath (param "HF_CACHE")))))
(deny file-write*
  (require-all
    (require-not (subpath (param "PROVIDER_HOME")))
    (require-not (subpath (param "PROVIDER_TMP")))
    (require-not (subpath (param "HF_CACHE")))))
(deny process-exec (require-not (subpath (param "OPTIQ_RUNTIME"))))
