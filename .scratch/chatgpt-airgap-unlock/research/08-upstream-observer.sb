(version 1)

; THROWAWAY PROTOTYPE ONLY. The upstream observer accepts gateway traffic on
; its assigned port and forwards only to the OptiQ provider port.
(allow default)
(deny network-outbound (remote ip))
(deny network-inbound (local ip))
(allow network-inbound (local ip (string-append "localhost:" (param "UPSTREAM_OBSERVER_PORT"))))
(allow network-outbound (remote ip (string-append "localhost:" (param "OPTIQ_PORT"))))

(deny file-read* (subpath (param "REAL_HOME")))
(deny file-write* (subpath (param "REAL_HOME")))
