        for line in patch.description.split("\n"):
            for wrapped in self._wrap(line, w - 8):
                desc_lines.append(wrapped)

        max_desc = h - y - 10
        for i, line in enumerate(desc_lines):
            if i < self.detail_scroll:
                continue
            if i >= self.detail_scroll + max_desc:
                break
            self._safe_addstr(y, 4, line)
            y += 1
        y += 1

        # Modifications section
        self._safe_addstr(y, 2, f" Modifications ({len(patch.modifications)}) ",
                          self._cp("header", bright=True))
        y += 1
        self._hline(y, 1, w - 2)
        y += 1

        for i, mod in enumerate(patch.modifications, 1):
            if y >= h - 5:
                break
            self._safe_addstr(y, 4, f"{i}.", self._cp("accent"))
            self._safe_addstr(y, 7, mod.file[:w - 10], self._cp("info"))
            y += 1
            if y >= h - 5:
                break
            search_display = mod.search if len(mod.search) < w - 14 else mod.search[:w - 17] + "…"
            replace_display = mod.replace if len(mod.replace) < 10 else mod.replace[:10]
            self._safe_addstr(y, 7, f"{search_display}", self._cp("revert"))
            self._safe_addstr(y, 7 + len(search_display) + 1, _ARR_R, self._dim())
            self._safe_addstr(y, 7 + len(search_display) + 3, replace_display, self._cp("applied", bright=True))
            y += 1
            if y >= h - 5:
                break
            if mod.description:
                self._safe_addstr(y, 9, mod.description, self._dim())
                y += 1
            y += 1

        # Footer
        fy = h - 3
        self._hline(fy, 1, w - 2)
        fy += 1
        hints = [
            ("Enter/ESC", self._cp("keyhint", bright=True)),
            (" Back  ", 0),
            ("Space", self._cp("keyhint", bright=True)),
            (" Toggle  ", 0),
            ("P", self._cp("keyhint", bright=True)),
            (" Preview  ", 0),
            ("L", self._cp("keyhint", bright=True)),
            (" Labels  ", 0),
            ("A", self._cp("revert", bright=True) if self.has_pending else self._dim()),
            (" Abort  ", 0),
            ("C", self._cp("pending", bright=True) if self.has_pending else self._dim()),
            (" Commit", 0),
        ]
        x = 2
        for text, attr in hints:
            self._safe_addstr(fy, x, text, attr)
            x += len(text)
        self._safe_addstr(fy, w - 7, "Q Quit", self._dim())

    # ── Preview View ──

    def _draw_preview(self):
        h, w = self.stdscr.getmaxyx()
        y = 0

        # Title
        self._safe_addstr(y, 1, " Preview Changes ", self._cp("title", bright=True))
        self._hline(y, 0, w, heavy=True)
        y += 2

        to_apply = self.pending_apply
        to_revert = self.pending_revert

        # Apply section
        if to_apply:
            self._safe_addstr(y, 2, f" Will Apply ({len(to_apply)}) ",
                              self._cp("header", bright=True))
            y += 1
            self._hline(y, 1, w - 2)
            y += 1
            for p in to_apply:
                if y >= h - 6:
                    break
                self._safe_addstr(y, 4, f"+ {p.id}", self._cp("applied", bright=True))
                y += 1
                self._safe_addstr(y, 6, p.short_desc[:w - 8], self._dim())
                y += 1
            y += 1

        # Revert section
        if to_revert:
            self._safe_addstr(y, 2, f" Will Revert ({len(to_revert)}) ",
                              self._cp("header", bright=True))
            y += 1
            self._hline(y, 1, w - 2)
            y += 1
            for p in to_revert:
                if y >= h - 6:
                    break
                self._safe_addstr(y, 4, f"- {p.id}", self._cp("revert", bright=True))
                y += 1
                self._safe_addstr(y, 6, p.short_desc[:w - 8], self._dim())
                y += 1
            y += 1

        # Empty state
        if not to_apply and not to_revert:
            self._safe_addstr(y, 4, "No changes pending.", self._dim())
            self._safe_addstr(y + 1, 4, "Toggle patches with Space to stage changes.", self._dim())
            y += 3

        # Summary
        if y < h - 4:
            self._hline(y, 1, w - 2)
            y += 1
            summary = f" {len(to_apply)} to apply  {_V}  {len(to_revert)} to revert "
            self._safe_addstr(y, 2, summary, self._cp("pending", bright=True) if (to_apply or to_revert) else self._dim())
            y += 2

        # Footer
        fy = h - 2
        if self.has_pending:
            self._safe_addstr(fy, 2, "C", self._cp("pending", bright=True))
            self._safe_addstr(fy, 3, " Commit   ", 0)
            self._safe_addstr(fy, 14, "A", self._cp("revert", bright=True))
            self._safe_addstr(fy, 15, " Abort   ", 0)
        self._safe_addstr(fy, 26, "Any key", self._cp("keyhint", bright=True))
        self._safe_addstr(fy, 34, " Back", 0)
        self._safe_addstr(fy, w - 7, "Q Quit", self._dim())

    # ── Commit View ──

    def _draw_commit(self):
        h, w = self.stdscr.getmaxyx()
        y = 0

        if self.commit_done:
            # Success or failure header
            if self.commit_success:
                self._safe_addstr(y, 1, f" {_CHECK} Commit Complete ",
                                  self._cp("success", bright=True))
            else:
                self._safe_addstr(y, 1, f" {_CROSS} Commit Failed ",
                                  self._cp("error", bright=True))
        else:
            self._safe_addstr(y, 1, " Committing Changes ",
                             self._cp("pending", bright=True))
        self._hline(y, 0, w, heavy=True)
        y += 2

        # Log entries
        for entry in self.commit_log:
            if y >= h - 3:
                break
            if entry.startswith("Done!"):
                self._safe_addstr(y, 2, f"{_CHECK} {entry}", self._cp("success", bright=True))
            elif entry.startswith("ERROR"):
                self._safe_addstr(y, 2, f"{_CROSS} {entry}", self._cp("error", bright=True))
            elif entry.startswith("WARNING"):
                self._safe_addstr(y, 2, f"⚠ {entry}", self._cp("pending"))
            elif entry.startswith("Signature verified"):
                self._safe_addstr(y, 2, f"{_CHECK} {entry}", self._cp("applied", bright=True))
            elif entry.startswith("  →"):
                self._safe_addstr(y, 4, entry, self._cp("info"))
            elif entry.startswith("Applying:"):
                self._safe_addstr(y, 2, entry, self._cp("accent"))
            elif entry.startswith("New asar hash"):
                self._safe_addstr(y, 2, entry, self._dim())
            elif entry.startswith("Rolling back") or entry.startswith("Rollback complete"):
                self._safe_addstr(y, 2, f"↻ {entry}", self._cp("pending", bright=True))
            elif entry.startswith("Install failed"):
                self._safe_addstr(y, 2, f"{_CROSS} {entry}", self._cp("error"))
            else:
                self._safe_addstr(y, 2, entry, self._dim())
            y += 1

        if self.commit_done:
            y += 1
            if y < h - 1:
                self._safe_addstr(y, 2, "Press any key to continue...", self._dim())

    # ── Helpers ──

    def _wrap(self, text, width):
        if not text:
            return [""]
        words = text.split()
        lines = []
        current = ""
        for word in words:
            if len(current) + len(word) + 1 <= width:
                current = f"{current} {word}".strip()
            else:
                if current:
                    lines.append(current)
                current = word
        if current:
            lines.append(current)
        return lines

