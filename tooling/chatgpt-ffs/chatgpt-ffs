    def _handle_list_key(self, key):
        if key in (self.curses.KEY_UP, ord("k")):
            self.cursor = max(0, self.cursor - 1)
        elif key in (self.curses.KEY_DOWN, ord("j")):
            self.cursor = min(len(self.patches) - 1, self.cursor + 1)
        elif key == ord(" "):
            if self.patches:
                patch = self.patches[self.cursor]
                self.desired[patch.id] = not self.desired.get(patch.id, False)
        elif key in (ord("\n"), self.curses.KEY_ENTER):
            if self.patches:
                self.detail_patch = self.patches[self.cursor]
                self.detail_scroll = 0
                self.view = "detail"
        elif key == ord("a"):
            if self.has_pending:
                self.abort_pending()
        elif key == ord("p"):
            self.view = "preview"
        elif key == ord("l"):
            self.view = "legend"
        elif key == ord("c"):
            if self.has_pending:
                self.view = "commit"
                self.commit_log = []
                self.commit_done = False
                self._do_commit()

    def _handle_detail_key(self, key):
        if key in (self.curses.KEY_UP, ord("k")):
            self.detail_scroll = max(0, self.detail_scroll - 1)
        elif key in (self.curses.KEY_DOWN, ord("j")):
            self.detail_scroll += 1
        elif key == ord(" "):
            if self.detail_patch:
                pid = self.detail_patch.id
                self.desired[pid] = not self.desired.get(pid, False)
        elif key in (ord("\n"), self.curses.KEY_ENTER, 27):
            self.view = "list"
        elif key == ord("a"):
            if self.has_pending:
                self.abort_pending()
        elif key == ord("p"):
            self.view = "preview"
        elif key == ord("c"):
            if self.has_pending:
                self.view = "commit"
                self.commit_log = []
                self.commit_done = False
                self._do_commit()

    def _handle_preview_key(self, key):
        if key == ord("c") and self.has_pending:
            self.view = "commit"
            self.commit_log = []
            self.commit_done = False
            self._do_commit()
        elif key == ord("a") and self.has_pending:
            self.abort_pending()
            self.view = "list"
        else:
            self.view = "list"

    def _do_commit(self):
        patches_to_apply = [p for p in self.patches if self.desired.get(p.id, False)]
        self.commit_log = []

        def progress(msg):
            self.commit_log.append(msg)
            self._draw()

        success, message = commit_changes(self.bundle, patches_to_apply, progress)
        self.commit_success = success
        if not success:
            self.commit_log.append(f"ERROR: {message}")
        self.commit_done = True
        self._draw()


