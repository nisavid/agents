def load_patches(external_dir=None):
    """Load built-in and external patches. Returns a list of Patch objects."""
    if external_dir is None:
        external_dir = EXTERNAL_PATCHES_DIR
    patches = list(BUILTIN_PATCHES)
    if external_dir.is_dir():
        for pf in sorted(external_dir.glob("*.json")):
            try:
                data = json.loads(pf.read_text())
                patch_list = data if isinstance(data, list) else [data]
                for pd in patch_list:
                    mods = [
                        Modification(
                            file=m["file"],
                            search=m["search"],
                            replace=m["replace"],
                            description=m.get("description", ""),
                        )
                        for m in pd.get("modifications", [])
                    ]
                    patches.append(
                        Patch(
                            id=pd["id"],
                            name=pd["name"],
                            category=pd.get("category", "uncategorized"),
                            labels=pd.get("labels", []),
                            description=pd.get("description", ""),
                            modifications=mods,
                        )
                    )
            except (json.JSONDecodeError, KeyError) as e:
                print(f"Warning: skipping {pf.name}: {e}", file=sys.stderr)
    return patches


def _detect_patch_states(bundle, patches):
    """Detect states for all patches. Returns {patch_id: state}.

    Returns 'unknown' for all patches if the asar is unreadable.
    """
    try:
        archive = AsarArchive(bundle.asar)
    except Exception:
        return {p.id: "unknown" for p in patches}
    return {p.id: p.detect_state(archive) for p in patches}


# ─── App Bundle ──────────────────────────────────────────────────────────────


class AppBundle:
    """Owns the full app-bundle mutation lifecycle.

    Encapsulates path layout, process management, backup, asar
    installation (copy → hash → plist → resign), signature verification,
    and rollback.  The signing-order constraint — nested helpers →
    frameworks → main app — stays inside this module.
    """

    def __init__(self, app_path):
        self.app_path = app_path
        self.resources = os.path.join(app_path, "Contents", "Resources")
        self.asar = os.path.join(self.resources, "app.asar")
        self.asar_orig = os.path.join(self.resources, "app.asar.orig")
        self.asar_unpacked = os.path.join(self.resources, "app.asar.unpacked")
        self.plist = os.path.join(app_path, "Contents", "Info.plist")
        self.frameworks = os.path.join(app_path, "Contents", "Frameworks")

    # ── Process management ──────────────────────────────────────────────

    def quit(self):
        """Quit the app if running."""
        proc_name = os.path.basename(self.app_path).replace(".app", "")
        result = subprocess.run(
            ["killall", proc_name], capture_output=True, text=True
        )
        if result.returncode == 0:
            import time
            time.sleep(1)

    # ── Backup ──────────────────────────────────────────────────────────

    def ensure_backup(self):
        """Ensure a pristine backup of the original asar exists.

        Returns True if a new backup was created, False if one existed.
        """
        if not os.path.exists(self.asar):
            raise FileNotFoundError(f"app.asar not found at {self.asar}")
        if not os.path.exists(self.asar_orig):
            shutil.copy2(self.asar, self.asar_orig)
            return True
        return False

    # ── Install + sign ──────────────────────────────────────────────────

    def install_asar(self, source_asar, progress_cb=None):
        """Copy an asar into place, update the integrity hash, and re-sign.

        Returns the SHA256 hash of the installed asar.  The hash is
        computed from the destination after copying.
        """
        report = _make_reporter(progress_cb)

        shutil.copy2(source_asar, self.asar)
        new_hash = sha256_file(self.asar)
        report("Updating integrity hash in Info.plist...")
        self._update_plist_hash(new_hash)
        self._resign(progress_cb=progress_cb)
        return new_hash

    def _update_plist_hash(self, asar_hash):
        """Update the ElectronAsarIntegrity hash in Info.plist."""
        import plistlib

        with open(self.plist, "rb") as f:
            plist = plistlib.load(f)
        if "ElectronAsarIntegrity" not in plist:
            plist["ElectronAsarIntegrity"] = {}
        if "Resources/app.asar" not in plist["ElectronAsarIntegrity"]:
            plist["ElectronAsarIntegrity"]["Resources/app.asar"] = {
                "algorithm": "SHA256",
                "hash": asar_hash,
            }
        else:
            plist["ElectronAsarIntegrity"]["Resources/app.asar"]["hash"] = asar_hash
        with open(self.plist, "wb") as f:
            plistlib.dump(plist, f)

    @staticmethod
    def _find_nested_code(framework_path):
        """Find all nested .app bundles inside a framework."""
        nested = []
        for root, dirs, files in os.walk(framework_path):
            for name in dirs:
                if name.endswith(".app"):
                    nested.append(os.path.join(root, name))
        return sorted(nested)

    def _resign(self, progress_cb=None):
        """Re-sign with ad-hoc signature and proper entitlements.

        Must sign nested helper apps inside frameworks before signing
        the frameworks themselves, then the main app last. Otherwise
        macOS library validation rejects the Team ID mismatch between
        the ad-hoc main app and still-original helper processes.
        """
        report = _make_reporter(progress_cb)

        codex_fw = os.path.join(self.frameworks, "Codex Framework.framework")
        sparkle_fw = os.path.join(self.frameworks, "Sparkle.framework")

        with tempfile.NamedTemporaryFile(
            mode="w", suffix=".plist", delete=False
        ) as f:
            f.write(APP_ENTITLEMENTS)
            app_ents = f.name
        with tempfile.NamedTemporaryFile(
            mode="w", suffix=".plist", delete=False
        ) as f:
            f.write(FW_ENTITLEMENTS)
            fw_ents = f.name

        try:
            report("Signing nested helper apps...")
            for fw in [codex_fw, sparkle_fw]:
                if not os.path.exists(fw):
                    continue
                for helper in self._find_nested_code(fw):
                    subprocess.run(
                        ["codesign", "--force", "--sign", "-",
                         "--entitlements", fw_ents, helper],
                        capture_output=True, text=True, check=False,
                    )
            if os.path.exists(codex_fw):
                report("Signing Codex Framework...")
                subprocess.run(
                    ["codesign", "--force", "--sign", "-",
                     "--entitlements", fw_ents, codex_fw],
                    capture_output=True, text=True, check=True,
                )
            if os.path.exists(sparkle_fw):
                report("Signing Sparkle Framework...")
                subprocess.run(
                    ["codesign", "--force", "--sign", "-", sparkle_fw],
                    capture_output=True, text=True, check=False,
                )
            report("Signing main app...")
            subprocess.run(
                ["codesign", "--force", "--sign", "-",
                 "--entitlements", app_ents, self.app_path],
                capture_output=True, text=True, check=True,
            )
        finally:
            for tmp_path in (app_ents, fw_ents):
                try:
                    os.unlink(tmp_path)
                except OSError:
                    pass

    # ── Verification ────────────────────────────────────────────────────

    def verify_signature(self):
        """Verify the code signature. Returns (bool, message)."""
        result = subprocess.run(
            ["codesign", "--verify", "--verbose", self.app_path],
            capture_output=True, text=True,
        )
        if result.returncode == 0:
            return True, "valid"
        return False, result.stderr.strip()

# ─── State Management ───────────────────────────────────────────────────────


class PatchState:
    """Owns the persistent state file schema.

    Tracks the installed asar hash and the list of applied patch IDs
    so that ``reapply`` can restore patches after an app update.
    """

    def __init__(self, installed_hash=None, applied_patches=None):
        self.installed_hash = installed_hash
        self.applied_patches = applied_patches or []

    @classmethod
    def load(cls):
        """Load state from disk, returning an empty state if missing or corrupt."""
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        if STATE_FILE.exists():
            try:
                data = json.loads(STATE_FILE.read_text())
                return cls(
                    installed_hash=data.get("installed_hash"),
                    applied_patches=data.get("applied_patches", []),
                )
            except json.JSONDecodeError:
                pass
        return cls()

    def save(self):
        """Persist state to disk."""
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        STATE_FILE.write_text(json.dumps({
            "installed_hash": self.installed_hash,
            "applied_patches": self.applied_patches,
        }, indent=2))

    def is_stale(self, current_hash):
        """True if the current asar hash differs from the stored one.

        Indicates the app was updated since the last tool operation.
        """
        return bool(self.installed_hash and current_hash != self.installed_hash)


# ─── Commit Logic ───────────────────────────────────────────────────────────


def _make_reporter(progress_cb=None):
    """Create a progress-reporting callable.

    Returns ``progress_cb`` if given, otherwise a no-op.  Eliminates the
    ``def report(msg): if progress_cb: progress_cb(msg)`` closure that
    was duplicated across four call sites.
    """
    return progress_cb or (lambda _: None)


def _dim_reporter(msg):
    """Print a progress message in dim style (for CLI commands)."""
    print(f"  {c.wrap(c.DIM, msg)}")


def commit_changes(bundle, patches_to_apply, progress_cb=None):
    """Extract original, apply selected patches, repack, install, and sign.

    Args:
        bundle: AppBundle instance
        patches_to_apply: list of Patch objects to apply
        progress_cb: optional callback(step_name) for progress updates

    Returns:
        (success: bool, message: str)

    If any step after installing the patched asar fails, the original
    asar is restored from backup so the app is never left broken.
    """
    report = _make_reporter(progress_cb)

    try:
        report("Quitting app if running...")
        bundle.quit()

        report("Ensuring original backup...")
        bundle.ensure_backup()

        with tempfile.TemporaryDirectory(prefix="codex-pm-") as tmpdir:
            extracted = os.path.join(tmpdir, "extracted")
            report("Extracting original asar...")
            archive = AsarArchive(bundle.asar_orig)
            unpacked_paths = archive.extract(
                extracted,
                unpacked_dir=bundle.asar_unpacked,
            )

            warnings = []
            for patch in patches_to_apply:
                report(f"Applying: {patch.name}...")
                count = patch.apply(extracted)
                report(f"  → {count} replacement(s)")
                if count == 0:
                    warnings.append(
                        f"{patch.id}: 0 matches "
                        f"(app may have been updated)"
                    )

            patched_asar = os.path.join(tmpdir, "app-patched.asar")
            report("Packing patched asar...")
            AsarArchive.pack(extracted, patched_asar, unpacked_paths=unpacked_paths)

            report(f"New asar hash: {sha256_file(patched_asar)[:16]}...")

            try:
                report("Installing patched asar...")
                new_hash = bundle.install_asar(patched_asar, progress_cb=report)

                report("Verifying signature...")
                ok, msg = bundle.verify_signature()
                if not ok:
                    raise RuntimeError(
                        f"Signature verification failed: {msg}"
                    )
                report("Signature verified ✓")
            except Exception as install_err:
                report(f"Install failed: {install_err}")
                report("Rolling back to original asar...")
                orig_hash = bundle.install_asar(
                    bundle.asar_orig, progress_cb=report
                )
                state = PatchState.load()
                state.installed_hash = orig_hash
                state.save()
                report("Verifying rollback signature...")
                ok, msg = bundle.verify_signature()
                if not ok:
                    report(f"WARNING: Rollback signature invalid: {msg}")
                report("Rollback complete — app restored to original state.")
                return False, f"Install failed and rolled back: {install_err}"

            state = PatchState.load()
            state.installed_hash = new_hash
            state.applied_patches = [p.id for p in patches_to_apply]
            state.save()

            for w in warnings:
                report(f"WARNING: {w}")

            report("Done!")
            if warnings:
                return True, (
                    "Changes committed with warnings "
                    f"({len(warnings)} patch(es) had 0 matches)"
                )
            return True, "Changes committed successfully"

    except Exception as e:
        return False, str(e)


