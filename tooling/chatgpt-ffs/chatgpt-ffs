class c:
    """ANSI escape codes for CLI color output. No-ops when stdout isn't a TTY."""

    _enabled = None

    @classmethod
    def _check(cls):
        if cls._enabled is None:
            cls._enabled = sys.stdout.isatty() and os.environ.get(
                "NO_COLOR", ""
            ) == ""
        return cls._enabled

    RESET = "\033[0m"
    BOLD = "\033[1m"
    DIM = "\033[2m"
    ITALIC = "\033[3m"
    UNDERLINE = "\033[4m"
    # 8 basic
    BLACK = "\033[30m"
    RED = "\033[31m"
    GREEN = "\033[32m"
    YELLOW = "\033[33m"
    BLUE = "\033[34m"
    MAGENTA = "\033[35m"
    CYAN = "\033[36m"
    WHITE = "\033[37m"
    # 8 bright
    B_BLACK = "\033[90m"
    B_RED = "\033[91m"
    B_GREEN = "\033[92m"
    B_YELLOW = "\033[93m"
    B_BLUE = "\033[94m"
    B_MAGENTA = "\033[95m"
    B_CYAN = "\033[96m"
    B_WHITE = "\033[97m"

    @classmethod
    def wrap(cls, code, text):
        """Wrap text with an ANSI code + reset, if color is enabled."""
        if cls._check():
            return f"{code}{text}{cls.RESET}"
        return text


# ─── Asar Format (pure Python, no dependencies) ─────────────────────────────


class AsarArchive:
    """A readable and writable asar archive.

    Parses the binary header once on open.  The asar format layout —
    pickle-header framing, 4-byte alignment, offset semantics — stays
    inside this module.  Readers use three methods: read a file, find
    files by glob, extract the whole archive.  Writers use the static
    ``pack`` method to build an archive from a directory.
    """

    def __init__(self, filepath):
        self.filepath = filepath
        self._header, self._data_start = self._parse_header(filepath)

    @staticmethod
    def _parse_header(filepath):
        """Detect header framing, parse JSON, compute data-start offset."""
        with open(filepath, "rb") as f:
            head = f.read(20)
            if len(head) < 16:
                raise ValueError("File too small to be an asar archive")
            if head[8] == 0x7B:
                json_offset = 8
                json_size = struct.unpack("<I", head[4:8])[0]
            elif head[16] == 0x7B:
                json_offset = 16
                json_size = struct.unpack("<I", head[12:16])[0]
            else:
                raise ValueError(
                    f"Cannot detect asar header format "
                    f"(byte 8=0x{head[8]:02x}, byte 16=0x{head[16]:02x})"
                )
            f.seek(json_offset)
            header = json.loads(f.read(json_size).decode("utf-8"))
            padded = math.ceil(json_size / 4) * 4
            data_start = json_offset + padded
            return header, data_start

    @property
    def header(self):
        return self._header

    def _resolve_node(self, internal_path):
        """Navigate the header tree to a leaf node. Returns dict or None."""
        node = self._header
        for part in internal_path.split("/"):
            if not isinstance(node, dict) or "files" not in node:
                return None
            node = node["files"].get(part)
            if node is None:
                return None
        return node if isinstance(node, dict) else None

    def read_file(self, internal_path):
        """Read a single file by its internal path. Returns bytes or None."""
        node = self._resolve_node(internal_path)
        if node is None or "offset" not in node:
            return None
        with open(self.filepath, "rb") as f:
            f.seek(int(node["offset"]) + self._data_start)
            return f.read(node["size"])

    def find_files(self, glob_pattern):
        """Find all internal paths matching a glob pattern."""
        results = []

        def walk(node, path):
            if not isinstance(node, dict):
                return
            if "files" in node:
                for name, child in node["files"].items():
                    walk(child, f"{path}/{name}" if path else name)
            elif "offset" in node and path:
                if fnmatch.fnmatch(path, glob_pattern):
                    results.append(path)

        walk(self._header, "")
        return sorted(results)

    def extract(self, dest_dir, unpacked_dir=None):
        """Extract the entire archive to a directory.

        Packed files are read from the asar binary.  Unpacked files
        (``"unpacked": true`` with no offset) are copied from the sibling
        ``unpacked_dir`` (defaults to ``filepath + ".unpacked"``).

        Returns a set of relative paths that are unpacked.  Pass this set
        to :meth:`AsarArchive.pack` so the repacked header preserves the flag.
        """
        os.makedirs(dest_dir, exist_ok=True)
        if unpacked_dir is None:
            unpacked_dir = self.filepath + ".unpacked"
        unpacked_paths = set()

        def extract_node(node, current_path, rel_path):
            if not isinstance(node, dict):
                return
            if "files" in node:
                os.makedirs(current_path, exist_ok=True)
                for name, child in node["files"].items():
                    child_rel = f"{rel_path}/{name}" if rel_path else name
                    extract_node(child, os.path.join(current_path, name), child_rel)
            elif "offset" in node:
                os.makedirs(os.path.dirname(current_path), exist_ok=True)
                with open(self.filepath, "rb") as f:
                    f.seek(int(node["offset"]) + self._data_start)
                    data = f.read(node["size"])
                with open(current_path, "wb") as out:
                    out.write(data)
                if node.get("executable"):
                    os.chmod(current_path, 0o755)
                else:
                    cur_mode = os.stat(current_path).st_mode
                    os.chmod(current_path, cur_mode & ~0o111)
            elif node.get("unpacked"):
                unpacked_paths.add(rel_path)
                src_file = os.path.join(unpacked_dir, rel_path)
                if os.path.exists(src_file):
                    os.makedirs(os.path.dirname(current_path), exist_ok=True)
                    shutil.copy2(src_file, current_path)
                    if node.get("executable"):
                        os.chmod(current_path, 0o755)
                    else:
                        cur_mode = os.stat(current_path).st_mode
                        os.chmod(current_path, cur_mode & ~0o111)

        extract_node(self._header, dest_dir, "")
        return unpacked_paths

    @staticmethod
    def _compute_integrity(data):
        """Compute asar integrity metadata for file content.

        Electron's asar format uses hex-encoded SHA256 digests (not base64).
        Mismatched encoding causes Electron's integrity validation to fail,
        which can freeze the app during module loading.
        """
        block_size = 4 * 1024 * 1024
        blocks = []
        if len(data) == 0:
            blocks.append(hashlib.sha256(b"").hexdigest())
        else:
            for i in range(0, len(data), block_size):
                block = data[i : i + block_size]
                blocks.append(hashlib.sha256(block).hexdigest())
        return {
            "algorithm": "SHA256",
            "hash": hashlib.sha256(data).hexdigest(),
            "blockSize": block_size,
            "blocks": blocks,
        }

    @staticmethod
    def pack(src_dir, dest_path, unpacked_paths=None):
        """Pack a directory into an asar archive.

        Files whose relative paths appear in ``unpacked_paths`` are marked
        "unpacked": true in the header (with size and integrity) but are
        excluded from the binary payload.  Their data must already exist in a
        sibling ``<dest_path>.unpacked/`` directory — pack does not create or
        modify that directory.
        """
        if unpacked_paths is None:
            unpacked_paths = set()
        file_table = {}
        file_chunks = []
        current_offset = 0

        def add_entry(full_path, name, table, rel_path):
            nonlocal current_offset
            if os.path.isdir(full_path):
                sub_table = {}
                for entry in sorted(os.listdir(full_path)):
                    child_rel = f"{rel_path}/{entry}" if rel_path else entry
                    add_entry(os.path.join(full_path, entry), entry, sub_table, child_rel)
                if sub_table:
                    table[name] = {"files": sub_table}
            elif os.path.isfile(full_path):
                with open(full_path, "rb") as f:
                    data = f.read()
                entry = {
                    "size": len(data),
                    "integrity": AsarArchive._compute_integrity(data),
                }
                if os.access(full_path, os.X_OK):
                    entry["executable"] = True
                if rel_path in unpacked_paths:
                    entry["unpacked"] = True
                else:
                    entry["offset"] = str(current_offset)
                    file_chunks.append(data)
                    current_offset += len(data)
                table[name] = entry

        for entry in sorted(os.listdir(src_dir)):
            add_entry(os.path.join(src_dir, entry), entry, file_table, entry)

        header = {"files": file_table}
        json_bytes = json.dumps(header, separators=(",", ":")).encode("utf-8")
        json_size = len(json_bytes)
        padded_size = math.ceil(json_size / 4) * 4

        outer_size = 8 + padded_size
        inner_size = 4 + padded_size

        with open(dest_path, "wb") as f:
            f.write(struct.pack("<I", 4))
            f.write(struct.pack("<I", outer_size))
            f.write(struct.pack("<I", inner_size))
            f.write(struct.pack("<I", json_size))
            f.write(json_bytes)
            if padded_size > json_size:
                f.write(b"\x00" * (padded_size - json_size))
            for chunk in file_chunks:
                f.write(chunk)


def sha256_file(path):
    """Compute SHA256 hex digest of a file."""
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


# ─── Patch Registry ─────────────────────────────────────────────────────────

@dataclass
class Modification:
    file: str
    search: str
    replace: str
    description: str = ""

    def apply_to(self, extracted_dir):
        """Apply this modification to the extracted directory.

        Returns the number of replacements made.
        """
        count = 0
        for root, dirs, files in os.walk(extracted_dir):
            for fname in sorted(files):
                full = os.path.join(root, fname)
                rel = os.path.relpath(full, extracted_dir)
                if fnmatch.fnmatch(rel, self.file):
                    with open(full, "r", errors="replace") as f:
                        content = f.read()
                    new_content, n = re.subn(self.search, self.replace, content)
                    if n > 0:
                        with open(full, "w") as f:
                            f.write(new_content)
                        count += n
        return count


@dataclass
class Patch:
    id: str
    name: str
    category: str
    labels: list = field(default_factory=list)
    description: str = ""
    modifications: list = field(default_factory=list)

    @property
    def short_desc(self):
        first_line = self.description.strip().split("\n")[0]
        return first_line[:120]

    def detect_state(self, archive):
        """Detect if this patch is applied.

        Returns 'applied', 'not_applied', or 'unknown'.
        """
        any_file_found = False
        for mod in self.modifications:
            matching_files = archive.find_files(mod.file)
            if not matching_files:
                continue
            any_file_found = True
            for fpath in matching_files:
                content = archive.read_file(fpath)
                if content is None:
                    continue
                text = content.decode("utf-8", errors="replace")
                if re.search(mod.search, text):
                    return "not_applied"
        return "applied" if any_file_found else "unknown"

    def apply(self, extracted_dir):
        """Apply all modifications. Returns total replacement count."""
        return sum(mod.apply_to(extracted_dir) for mod in self.modifications)


