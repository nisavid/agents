# ─── Verify ─────────────────────────────────────────────────────────────────


def cmd_verify(patches, bundle):
    """Verify app integrity: asar, backup, signature, and patch state.

    Runs a closed-loop check that the app.asar is readable, the backup
    exists, the code signature is valid, and the recorded state matches
    the actual patch states detected in the asar.
    """
    ok = True
    print()
    print(f"  {c.wrap(c.B_CYAN + c.BOLD, 'ChatGPT FFS — Verification')}")
    print()

    # 1. app.asar exists and is readable
    asar_path = bundle.asar
    if not os.path.exists(asar_path):
        print(f"  {c.wrap(c.RED + c.BOLD, _CROSS)} app.asar not found at {asar_path}")
        return False
    try:
        archive = AsarArchive(asar_path)
        print(f"  {c.wrap(c.GREEN, _CHECK)} app.asar is readable")
    except Exception as e:
        print(f"  {c.wrap(c.RED + c.BOLD, _CROSS)} app.asar is corrupted: {e}")
        return False

    # 2. Backup exists
    if os.path.exists(bundle.asar_orig):
        print(f"  {c.wrap(c.GREEN, _CHECK)} Backup exists (app.asar.orig)")
    else:
        print(f"  {c.wrap(c.YELLOW, '⚠')} No backup — first patch will create one")

    # 3. Signature
    sig_ok, sig_msg = bundle.verify_signature()
    if sig_ok:
        print(f"  {c.wrap(c.GREEN, _CHECK)} Code signature valid")
    else:
        print(f"  {c.wrap(c.RED + c.BOLD, _CROSS)} Code signature invalid: {sig_msg}")
        ok = False

    # 4. Hash consistency (diagnostic only — does not affect pass/fail).
    #    A mismatch indicates the asar changed since the last tool operation
    #    (restore, rollback, or app update) and helps explain why patches
    #    may show as "pending reapply" in step 5.
    state = PatchState.load()
    stored_hash = state.installed_hash
    if stored_hash:
        current_hash = sha256_file(asar_path)
        if current_hash == stored_hash:
            print(f"  {c.wrap(c.GREEN, _CHECK)} Asar hash matches state record")
        else:
            print(f"  {c.wrap(c.YELLOW, '⚠')} Asar hash differs from state record "
                  f"(app may have been updated)")

    # 5. Patch states
    recorded_ids = set(state.applied_patches)
    actual_ids = set()
    for p in patches:
        st = p.detect_state(archive)
        if st == "applied":
            actual_ids.add(p.id)
        elif st == "unknown":
            print(f"  {c.wrap(c.YELLOW, '⚠')} {p.id}: state unknown (file not found)")

    if recorded_ids == actual_ids:
        print(f"  {c.wrap(c.GREEN, _CHECK)} Patch state matches record "
              f"({len(actual_ids)} applied)")
    else:
        missing = recorded_ids - actual_ids
        extra = actual_ids - recorded_ids
        if missing:
            # Patches saved in state but not detected in the asar.
            # This is the expected "pending reapply" state after
            # restore, rollback, or app update — not drift.  The
            # signature check (step 3) already validated the app.
            ids = ", ".join(c.wrap(c.YELLOW, i) for i in sorted(missing))
            print(f"  {c.wrap(c.YELLOW, '⚠')} Pending reapply: {ids}")
        if extra:
            # Patches detected in the asar but not in the state record.
            # This indicates unexpected drift.
            ids = ", ".join(c.wrap(c.YELLOW, i) for i in sorted(extra))
            ok = False
            print(f"  {c.wrap(c.RED + c.BOLD, _CROSS)} Detected but not recorded: {ids}")

    print()
    if ok:
        print(f"  {c.wrap(c.GREEN + c.BOLD, _CHECK)} All checks passed.")
    else:
        print(f"  {c.wrap(c.RED + c.BOLD, _CROSS)} Verification failed.")
    return ok


# ─── Update Workflow ───────────────────────────────────────────────────────


def cmd_restore(patches, bundle):
    """Restore pristine app.asar from backup, preserving the applied-patch list.

    Saves the set of currently-applied patches to state so ``reapply`` can
    restore them after an app update.  Then copies ``app.asar.orig`` over
    ``app.asar``, updates the integrity hash, and re-signs — leaving the app
    in a clean state that can safely accept a Sparkle or manual update.
    """
    # Detect which patches are currently applied so reapply can restore them.
    states = _detect_patch_states(bundle, patches)
    applied_ids = [
        p.id for p in patches
        if states[p.id] == "applied"
    ]

    state = PatchState.load()
    state.applied_patches = applied_ids

    orig = bundle.asar_orig
    if not os.path.exists(orig):
        # Already pristine (e.g. app was just updated and no backup exists).
        state.installed_hash = sha256_file(bundle.asar)
        state.save()
        print(f"  {c.wrap(c.YELLOW, '⚠')} No backup found — app is already pristine.")
        if applied_ids:
            ids = ", ".join(c.wrap(c.CYAN, pid) for pid in applied_ids)
            print(f"  {c.wrap(c.DIM, 'Saved')} {ids} {c.wrap(c.DIM, 'for reapply.')}")
        else:
            print(f"  {c.wrap(c.DIM, 'No patches to reapply.')}")
        return

    report = _dim_reporter

    try:
        report("Quitting app if running...")
        bundle.quit()

        report("Restoring pristine app.asar from backup...")
        new_hash = bundle.install_asar(orig, progress_cb=report)

        state.installed_hash = new_hash
        state.save()

        report("Verifying signature...")
        ok, msg = bundle.verify_signature()
        if not ok:
            report(f"WARNING: Signature verification failed: {msg}")
        else:
            report("Signature verified ✓")

        print(f"\n  {c.wrap(c.GREEN + c.BOLD, '✓')} {c.wrap(c.GREEN, 'App restored to pristine state.')}")
        if applied_ids:
            ids = ", ".join(c.wrap(c.CYAN, pid) for pid in applied_ids)
            print(f"  {c.wrap(c.DIM, 'Saved for reapply:')} {ids}")
            print(f"  {c.wrap(c.DIM, 'Run')} {c.wrap(c.BOLD, 'chatgpt-ffs reapply')} "
                  f"{c.wrap(c.DIM, 'after updating the app.')}")
        else:
            print(f"  {c.wrap(c.DIM, 'No patches were applied — nothing to reapply.')}")
    except Exception as e:
        print(f"\n  {c.wrap(c.RED + c.BOLD, '✗')} {c.wrap(c.RED, str(e))}",
              file=sys.stderr)
        sys.exit(1)


def cmd_reapply(patches, bundle):
    """Re-apply the patch set saved by ``restore``.

    Reads ``applied_patches`` from state.  If the current ``app.asar`` hash
    differs from the stored ``installed_hash`` (i.e. the app was updated),
    the stale ``app.asar.orig`` backup is deleted so ``ensure_backup``
    creates a fresh one from the new version.
    """
    state = PatchState.load()
    saved_ids = state.applied_patches

    if not saved_ids:
        print(f"  {c.wrap(c.YELLOW, '⚠')} No saved patches to reapply.")
        print(f"  {c.wrap(c.DIM, 'Run')} {c.wrap(c.BOLD, 'chatgpt-ffs apply <patches>')} "
              f"{c.wrap(c.DIM, 'instead.')}")
        return

    # Detect stale backup: if the current asar hash doesn't match what we
    # stored at restore time, the app was updated and app.asar.orig is stale.
    if state.is_stale(sha256_file(bundle.asar)):
        orig = bundle.asar_orig
        if os.path.exists(orig):
            print(f"  {c.wrap(c.DIM, 'App updated — refreshing backup...')}")
            os.remove(orig)

    # Resolve saved IDs to Patch objects.
    selected = []
    unknown = []
    for pid in saved_ids:
        patch = next((p for p in patches if p.id == pid), None)
        if patch:
            selected.append(patch)
        else:
            unknown.append(pid)

    if unknown:
        ids = ", ".join(c.wrap(c.YELLOW, pid) for pid in unknown)
        print(f"  {c.wrap(c.YELLOW, '⚠')} Skipping unknown patches: {ids}",
              file=sys.stderr)

    if not selected:
        print(f"  {c.wrap(c.RED + c.BOLD, '✗')} No applicable patches found.",
              file=sys.stderr)
        sys.exit(1)

    count = len(selected)
    label = "patch" if count == 1 else "patches"
    ids = ", ".join(c.wrap(c.CYAN, p.id) for p in selected)
    print(f"  {c.wrap(c.DIM, f'Reapplying {count} {label}:')} {ids}")

    success, msg = commit_changes(bundle, selected,
                                  _dim_reporter)
    if success:
        print(f"\n  {c.wrap(c.GREEN + c.BOLD, '✓')} {c.wrap(c.GREEN, msg)}")
    else:
        print(f"\n  {c.wrap(c.RED + c.BOLD, '✗')} {c.wrap(c.RED, msg)}",
              file=sys.stderr)
        sys.exit(1)


def cmd_update(patches, bundle):
    """Guided update workflow: restore → wait for app update → reapply.

    Restores the pristine app, prints update instructions, waits for the
    user to confirm the update is complete, then reapplies saved patches.
    """
    print(f"  {c.wrap(c.B_CYAN + c.BOLD, 'ChatGPT FFS — Update Workflow')}")
    print()

    # Step 1: Restore
    print(f"  {c.wrap(c.BOLD, 'Step 1:')} Restore pristine app")
    cmd_restore(patches, bundle)
    print()

    state = PatchState.load()
    saved_ids = state.applied_patches
    if not saved_ids:
        print(f"  {c.wrap(c.DIM, 'No patches to reapply — done.')}")
        return

    # Step 2: User updates the app
    print(f"  {c.wrap(c.BOLD, 'Step 2:')} Update ChatGPT.app")
    print(f"  {c.wrap(c.DIM, 'The app has been restored to its pristine state.')}")
    print(f"  {c.wrap(c.DIM, 'Update it now via:')}")
    print(f"    {c.wrap(c.CYAN, '• Sparkle auto-update (restart the app and let it update)')}")
    print(f"    {c.wrap(c.CYAN, '• Manual download and replace')}")
    print()
    try:
        input(f"  {c.wrap(c.YELLOW + c.BOLD, 'Press Enter when the update is complete...')}")
    except (EOFError, KeyboardInterrupt):
        print(f"\n  {c.wrap(c.YELLOW, '⚠')} Update interrupted.")
        print(f"  {c.wrap(c.DIM, 'Run')} {c.wrap(c.BOLD, 'chatgpt-ffs reapply')} "
              f"{c.wrap(c.DIM, 'when ready.')}")
        return
    print()

    # Step 3: Reapply
    print(f"  {c.wrap(c.BOLD, 'Step 3:')} Reapply patches")
    cmd_reapply(patches, bundle)


# ─── Install ────────────────────────────────────────────────────────────────

INSTALL_LINK_NAME = "chatgpt-ffs"


def cmd_install():
    """Install chatgpt-ffs into ~/.local/bin and ensure PATH activation."""
    LOCAL_BIN.mkdir(parents=True, exist_ok=True)

    # Ensure ~/.local/bin/env exists and activates ~/.local/bin on PATH.
    # This file is sourced by ~/.profile and ~/.zshenv.  If it already
    # exists (e.g. created by another tool), leave it untouched.
    if not LOCAL_BIN_ENV.exists():
        LOCAL_BIN_ENV.write_text(LOCAL_BIN_ENV_CONTENT)
        LOCAL_BIN_ENV.chmod(0o644)
        print(f"  {c.wrap(c.DIM, 'created')} {c.wrap(c.CYAN, str(LOCAL_BIN_ENV))}")
    else:
        print(f"  {c.wrap(c.DIM, 'exists')}  {c.wrap(c.CYAN, str(LOCAL_BIN_ENV))}")

    if not LOCAL_BIN_ENV_FISH.exists():
        LOCAL_BIN_ENV_FISH.write_text(LOCAL_BIN_ENV_FISH_CONTENT)
        LOCAL_BIN_ENV_FISH.chmod(0o644)
        print(f"  {c.wrap(c.DIM, 'created')} {c.wrap(c.CYAN, str(LOCAL_BIN_ENV_FISH))}")
    else:
        print(f"  {c.wrap(c.DIM, 'exists')}  {c.wrap(c.CYAN, str(LOCAL_BIN_ENV_FISH))}")

    # Remove a stale symlink from the previous tool name if present.
    old_link = LOCAL_BIN / "codex-patch-manager"
    if old_link.is_symlink() or old_link.exists():
        old_link.unlink()
        print(f"  {c.wrap(c.DIM, 'removed')} {c.wrap(c.CYAN, str(old_link))} {c.wrap(c.DIM, '(old name)')}")

    # Symlink the script into ~/.local/bin so updates to the repo copy
    # are picked up automatically.
    target = LOCAL_BIN / INSTALL_LINK_NAME
    script = SCRIPT_DIR / "chatgpt-ffs"
    if target.is_symlink() or target.exists():
        target.unlink()
    target.symlink_to(script)
    target.chmod(0o755)
    print(f"  {c.wrap(c.DIM, 'linked')}  {c.wrap(c.CYAN, str(target))} {c.wrap(c.DIM, '->')} {c.wrap(c.CYAN, str(script))}")

    # Check whether ~/.local/bin is on PATH in the *current* shell.
    path_dirs = os.environ.get("PATH", "").split(":")
    on_path = str(LOCAL_BIN) in path_dirs
    if on_path:
        print(f"\n  {c.wrap(c.GREEN + c.BOLD, '✓')} Installed. {c.wrap(c.CYAN, INSTALL_LINK_NAME)} is on your PATH.")
        print(f"  Run {c.wrap(c.BOLD, 'chatgpt-ffs')} from anywhere.")
    else:
        print(f"\n  {c.wrap(c.GREEN + c.BOLD, '✓')} Installed to {c.wrap(c.CYAN, str(LOCAL_BIN))}.")
        print(f"  {c.wrap(c.YELLOW, '⚠')} {c.wrap(c.BOLD, str(LOCAL_BIN))} is not on your PATH in this shell.")
        print(f"  It will be activated in new shells via {c.wrap(c.CYAN, '~/.local/bin/env')},")
        print(f"  which is sourced by {c.wrap(c.CYAN, '~/.profile')} and {c.wrap(c.CYAN, '~/.zshenv')}.")
        print(f"  For this shell: {c.wrap(c.BOLD, 'source ~/.local/bin/env')}")




# ─── Main ───────────────────────────────────────────────────────────────────

def main():
    import argparse

    parser = argparse.ArgumentParser(
        description="ChatGPT FFS — asar patch manager for ChatGPT.app",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Run without arguments to launch the interactive TUI.\n"
            "Add patches to patches.d/*.json for extensibility."
        ),
    )
    parser.add_argument("--app", default=DEFAULT_APP, help="Path to ChatGPT.app")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("list", help="List patches and their states")
    sub.add_parser("status", help="Brief status of applied patches")
    sub.add_parser("verify", help="Verify app integrity, signature, and patch state")
    p_apply = sub.add_parser("apply", help="Apply patches")
    p_apply.add_argument("patches", nargs="+", help="Patch IDs to apply")
    p_revert = sub.add_parser("revert", help="Revert patches")
    p_revert.add_argument(
        "patches", nargs="*", default=["all"], help="Patch IDs to revert (or 'all')"
    )
    sub.add_parser("restore", help="Restore pristine app.asar (pre-update step)")
    sub.add_parser("reapply", help="Reapply saved patches (post-update step)")
    sub.add_parser("update", help="Guided restore → update → reapply workflow")
    sub.add_parser("tui", help="Launch interactive TUI")
    sub.add_parser("install", help="Install to ~/.local/bin and ensure PATH activation")

    args = parser.parse_args()

    if args.command == "install":
        cmd_install()
        return

    bundle = AppBundle(args.app)

    if not os.path.exists(bundle.asar):
        app_short = os.path.basename(bundle.app_path)
        print(
            f"Error: {bundle.asar} not found.\n"
            f"Is {app_short} installed at {bundle.app_path}?",
            file=sys.stderr,
        )
        sys.exit(1)

    patches = load_patches()

    if args.command == "list":
        cmd_list(patches, bundle)
    elif args.command == "status":
        cmd_status(patches, bundle)
    elif args.command == "verify":
        ok = cmd_verify(patches, bundle)
        sys.exit(0 if ok else 1)
    elif args.command == "apply":
        cmd_apply(patches, bundle, args.patches)
    elif args.command == "revert":
        cmd_revert(patches, bundle, args.patches)
    elif args.command == "restore":
        cmd_restore(patches, bundle)
    elif args.command == "reapply":
        cmd_reapply(patches, bundle)
    elif args.command == "update":
        cmd_update(patches, bundle)
    elif args.command == "tui":
        _run_tui(patches, bundle)
    else:
        _run_tui(patches, bundle)


def _run_tui(patches, bundle):
    import curses

    states = _detect_patch_states(bundle, patches)

    def tui_main(stdscr):
        ui = PatchManagerTUI(stdscr, patches, states, bundle)
        ui.run()

    try:
        curses.wrapper(tui_main)
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
