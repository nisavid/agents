            for label, (d, desc) in sorted(LABEL_META.items()):
                if d != dim_key:
                    continue
                if y >= h - 4:
                    break
                tag = f" {label} "
                self._safe_addstr(y, 4, tag, self._cp(dim_color))
                desc_max = w - 4 - len(tag) - 3
                desc_display = desc[:desc_max] if len(desc) > desc_max else desc
                self._safe_addstr(y, 4 + len(tag) + 2, desc_display,
                                  self._dim())
                y += 1
