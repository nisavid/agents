class PatchManagerTUI:
    VIEWS = ("list", "detail", "preview", "commit", "legend")

    def __init__(self, stdscr, patches, states, bundle):
        import curses
        self.stdscr = stdscr
        self.curses = curses
        self.patches = patches
        self.states = states
        self.bundle = bundle
        self.view = "list"
        self.cursor = 0
        self.scroll = 0
        self.detail_patch = None
        self.detail_scroll = 0
        self.desired = {
            p.id: self.states.get(p.id) == "applied" for p in patches
        }
        self.commit_log = []
        self.commit_done = False
        self.commit_success = False
        self.message = None
        self.message_age = 0

    @property
    def pending_apply(self):
        return [
            p for p in self.patches
            if self.desired.get(p.id, False)
            and self.states.get(p.id) != "applied"
        ]

    @property
    def pending_revert(self):
        return [
            p for p in self.patches
            if not self.desired.get(p.id, False)
            and self.states.get(p.id) == "applied"
        ]

    @property
    def has_pending(self):
        return bool(self.pending_apply or self.pending_revert)

    def abort_pending(self):
        """Discard all pending toggles: reset desired selection to current state."""
        for p in self.patches:
            self.desired[p.id] = self.states.get(p.id) == "applied"

    def run(self):
        try:
            self.curses.curs_set(0)
        except self.curses.error:
            pass
        self._init_colors()
        while True:
            self._draw()
            key = self.stdscr.getch()
            if key == ord("q") or key == 27:
                if self.view == "list":
                    break
                elif self.view == "commit" and not self.commit_done:
                    pass  # can't quit mid-commit
                else:
                    self.view = "list"
                    self._reset_view_state()
            elif self.view == "list":
                self._handle_list_key(key)
            elif self.view == "detail":
                self._handle_detail_key(key)
            elif self.view == "preview":
                self._handle_preview_key(key)
            elif self.view == "legend":
                self.view = "list"
            elif self.view == "commit":
                if self.commit_done:
                    self._reset_view_state()
                    self.view = "list"
                    self.states = _detect_patch_states(
                        self.bundle, self.patches
                    )
                    for p in self.patches:
                        self.desired[p.id] = self.states[p.id] == "applied"

    def _reset_view_state(self):
        self.commit_log = []
        self.commit_done = False
        self.commit_success = False
        self.detail_scroll = 0

    def _init_colors(self):
        # Degrade gracefully to monochrome when the terminal lacks color
        # support (some PTYs/terminfo entries report COLORS=0 / COLOR_PAIRS=-1).
        if not self.curses.has_colors() or self.curses.COLORS < 1:
            return
        try:
            self.curses.start_color()
        except self.curses.error:
            return
        try:
            self.curses.use_default_colors()
            bg = -1
        except self.curses.error:
            bg = self.curses.COLOR_BLACK

        p = _CP
        cp = self.curses.init_pair
        try:
            cp(p["title"],     self.curses.COLOR_CYAN,    bg)
            cp(p["subtitle"],  self.curses.COLOR_CYAN,    bg)
            cp(p["dim"],       self.curses.COLOR_WHITE,   bg)  # +A_DIM for gray
            cp(p["applied"],   self.curses.COLOR_GREEN,   bg)
            cp(p["pending"],   self.curses.COLOR_YELLOW,  bg)
            cp(p["revert"],    self.curses.COLOR_RED,     bg)
            cp(p["info"],      self.curses.COLOR_CYAN,    bg)
            cp(p["accent"],    self.curses.COLOR_MAGENTA, bg)
            cp(p["success"],   self.curses.COLOR_GREEN,   bg)
            cp(p["error"],     self.curses.COLOR_RED,     bg)
            cp(p["border"],    self.curses.COLOR_WHITE,   bg)  # +A_DIM
            cp(p["keyhint"],   self.curses.COLOR_CYAN,    bg)
            cp(p["header"],    self.curses.COLOR_BLUE,    bg)
            cp(p["select"],    self.curses.COLOR_BLACK,   self.curses.COLOR_BLUE)
            cp(p["badge_on"],  self.curses.COLOR_BLACK,   self.curses.COLOR_GREEN)
            cp(p["badge_off"], self.curses.COLOR_BLACK,   self.curses.COLOR_WHITE)
            cp(p["badge_pend"],self.curses.COLOR_BLACK,   self.curses.COLOR_YELLOW)
            cp(p["badge_rev"], self.curses.COLOR_BLACK,   self.curses.COLOR_RED)
            cp(p["badge_unk"], self.curses.COLOR_BLACK,   self.curses.COLOR_WHITE)
        except self.curses.error:
            # Color pairs unavailable; render in monochrome. color_pair()
            # calls elsewhere return inert attributes in that case.
            pass

    def _cp(self, name, bright=False):
        """Get color attribute for a named pair, optionally brightened."""
        attr = self.curses.color_pair(_CP[name])
        if bright:
            attr |= self.curses.A_BOLD
        return attr

    def _dim(self, name="default"):
        """Get dimmed color attribute."""
        return self.curses.color_pair(_CP[name]) | self.curses.A_DIM

    def _safe_addstr(self, y, x, text, attr=0):
        h, w = self.stdscr.getmaxyx()
        if y < 0 or y >= h or x >= w:
            return
        text = text[: max(0, w - x - 1)]
        if text:
            try:
                self.stdscr.addstr(y, x, text, attr)
            except self.curses.error:
                pass

    def _hline(self, y, x, length, heavy=False):
        """Draw a horizontal line."""
        char = _H if heavy else _h
        self._safe_addstr(y, x, char * length, self._dim("border"))

    def _draw(self):
        self.stdscr.erase()
        h, w = self.stdscr.getmaxyx()
        if h < 12 or w < 64:
            self._safe_addstr(0, 0, "Terminal too small (need 64×12+)")
            return
        if self.view == "list":
            self._draw_list()
        elif self.view == "detail":
            self._draw_detail()
        elif self.view == "preview":
            self._draw_preview()
        elif self.view == "commit":
            self._draw_commit()
        elif self.view == "legend":
            self._draw_label_legend()
        self.stdscr.refresh()

    # ── List View ──

    def _draw_list(self):
        h, w = self.stdscr.getmaxyx()

        # Header
        self._safe_addstr(0, 1, " ChatGPT FFS ",
                          self._cp("title", bright=True))
        self._hline(1, 0, w, heavy=True)

        # App path
        app_short = self.bundle.app_path
        if len(app_short) > w - 12:
            app_short = "…" + app_short[-(w - 14):]
        self._safe_addstr(2, 2, "App:", self._dim())
        self._safe_addstr(2, 7, app_short, self._cp("subtitle"))

        # Column header
        y = 4
        self._safe_addstr(y, 2, "St", self._cp("header", bright=True) | self.curses.A_UNDERLINE)
        self._safe_addstr(y, 6, "Patch", self._cp("header", bright=True) | self.curses.A_UNDERLINE)
        cat_x = max(w - 22, 40)
        self._safe_addstr(y, cat_x, "Category", self._cp("header", bright=True) | self.curses.A_UNDERLINE)
        y += 1
        self._hline(y, 1, w - 2)
        y += 1

        # Scroll logic
        visible = h - y - 6
        if self.cursor < self.scroll:
            self.scroll = self.cursor
        elif self.cursor >= self.scroll + visible:
            self.scroll = self.cursor - visible + 1

        # Patch rows
        for i, patch in enumerate(self.patches):
            if i < self.scroll:
                continue
            if i >= self.scroll + visible:
                break
            if y >= h - 6:
                break

            state = self.states.get(patch.id, "unknown")
            desired = self.desired.get(patch.id, False)
            is_applied = state == "applied"
            is_selected = i == self.cursor

            # Status badge
            if is_applied and desired:
                badge = " ON "
                badge_attr = self.curses.color_pair(_CP["badge_on"])
            elif not is_applied and not desired:
                badge = "off "
                badge_attr = self.curses.color_pair(_CP["badge_off"]) | self.curses.A_DIM
            elif is_applied and not desired:
                badge = "rev "
                badge_attr = self.curses.color_pair(_CP["badge_rev"])
            else:
                badge = "add "
                badge_attr = self.curses.color_pair(_CP["badge_pend"])

            # Cursor marker
            marker = _TRI if is_selected else "  "
            marker_attr = self._cp("accent", bright=True) if is_selected else 0

            # Name color
            if is_applied and desired:
                name_attr = self._cp("applied", bright=True)
            elif is_applied and not desired:
                name_attr = self._cp("revert")
            elif not is_applied and desired:
                name_attr = self._cp("pending", bright=True)
            else:
                name_attr = 0

            # Category color
            cat_attr = self._cp("accent")

            # Apply selection highlight
            if is_selected:
                badge_attr = self.curses.color_pair(_CP["select"])
                marker_attr = self.curses.color_pair(_CP["select"]) | self.curses.A_BOLD
                name_attr = self.curses.color_pair(_CP["select"]) | self.curses.A_BOLD
                cat_attr = self.curses.color_pair(_CP["select"])

            self._safe_addstr(y, 0, marker, marker_attr)
            self._safe_addstr(y, 3, badge, badge_attr)
            # Truncate name if too long
            name_max = cat_x - 9
            name = patch.name[:name_max]
            self._safe_addstr(y, 8, name, name_attr)
            self._safe_addstr(y, cat_x, patch.category, cat_attr)
            y += 1

        # Labels bar for selected patch
        if self.patches:
            sel_patch = self.patches[self.cursor]
            ly = h - 5
            self._hline(ly, 1, w - 2)
            ly += 1
            self._draw_labels_bar(ly, w, sel_patch)

        # Footer
        fy = h - 3
        self._hline(fy, 1, w - 2)
        fy += 1

        # Key hints — color-coded by action type
        hints = [
            ("↑↓", self._dim()),
            (" Navigate  ", 0),
            ("Space", self._cp("keyhint", bright=True)),
            (" Toggle  ", 0),
            ("Enter", self._cp("keyhint", bright=True)),
            (" Details  ", 0),
            ("P", self._cp("keyhint", bright=True)),
            (" Preview  ", 0),
            ("L", self._cp("keyhint", bright=True)),
            (" Labels  ", 0),
            ("A", self._cp("revert", bright=True) if self.has_pending else self._dim()),
            (" Abort  ", 0),
            ("C", self._cp("pending", bright=True) if self.has_pending else self._dim()),
            (" Commit", 0),
        ]
        x = 2
        for text, attr in hints:
            self._safe_addstr(fy, x, text, attr)
            x += len(text)
        self._safe_addstr(fy, w - 7, "Q Quit", self._dim())

        # Status line
        applied_count = sum(1 for p in self.patches if self.states.get(p.id) == "applied")
        pending = len(self.pending_apply) + len(self.pending_revert)
        parts = [
            (f" {applied_count}", self._cp("applied", bright=True)),
            (f"/{len(self.patches)} applied", self._dim()),
        ]
        if pending:
            parts.append((f"  {_DOT} ", self._cp("pending", bright=True)))
            parts.append((f"{pending} pending", self._cp("pending", bright=True)))
        x = 2
        for text, attr in parts:
            self._safe_addstr(h - 1, x, text, attr)
            x += len(text)

    # ── Detail View ──

    def _draw_detail(self):
        h, w = self.stdscr.getmaxyx()
        patch = self.detail_patch
        if not patch:
            self.view = "list"
            return

        y = 0
        # Title bar
        self._safe_addstr(y, 1, " Patch Details ", self._cp("title", bright=True))
        self._hline(y, 0, w, heavy=True)
        y += 2

        # Patch name
        name = patch.name[:w - 4]
        self._safe_addstr(y, 2, name, self.curses.A_BOLD)
        y += 1
        self._hline(y, 1, w - 2)
        y += 2

        # Metadata fields
        state = self.states.get(patch.id, "unknown")
        desired = self.desired.get(patch.id, False)

        fields = [
            ("ID", patch.id, self._cp("info")),
            ("Category", patch.category, self._cp("accent")),
        ]
        for label, value, val_attr in fields:
            self._safe_addstr(y, 4, f"{label}:", self._dim())
            self._safe_addstr(y, 14, value, val_attr)
            y += 1

        # Status field with badge
        self._safe_addstr(y, 4, "Status:", self._dim())
        if state == "applied":
            if desired:
                self._safe_addstr(y, 14, f" {_CHECK} APPLIED ", self.curses.color_pair(_CP["badge_on"]))
            else:
                self._safe_addstr(y, 14, f" ↻ PENDING REVERT ", self.curses.color_pair(_CP["badge_rev"]))
        elif state == "not_applied":
            if desired:
                self._safe_addstr(y, 14, f" + PENDING APPLY ", self.curses.color_pair(_CP["badge_pend"]))
            else:
                self._safe_addstr(y, 14, f" {_CIRC} NOT APPLIED ", self.curses.color_pair(_CP["badge_off"]) | self.curses.A_DIM)
        else:
            self._safe_addstr(y, 14, " ? UNKNOWN ", self.curses.color_pair(_CP["badge_unk"]))
        y += 2

        # Labels section
        if patch.labels:
            self._safe_addstr(y, 2, " Labels ",
                              self._cp("header", bright=True))
            y += 1
            self._hline(y, 1, w - 2)
            y += 1
            for dim_key, dim_name, dim_color in LABEL_DIMENSIONS:
                dim_labels = [
                    l for l in patch.labels
                    if LABEL_META.get(l, ("?",))[0] == dim_key
                ]
                if not dim_labels:
                    continue
                self._safe_addstr(y, 4, f"{dim_name}:", self._dim())
                lx = 18
                for label in dim_labels:
                    tag = f" {label} "
