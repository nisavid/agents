            elif dim == "beh":
                attr = self._cp("applied", bright=True)
            else:
                attr = 0
            tag = f" {label} "
            if x + len(tag) >= w:
                y += 1
                x = 2
                h_max = self.stdscr.getmaxyx()[0]
                if y >= h_max - 3:
                    break
            self._safe_addstr(y, x, tag, attr)
            x += len(tag) + 1

