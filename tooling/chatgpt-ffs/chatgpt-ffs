    def _draw_labels_bar(self, y, w, patch):
        """Draw labels for the selected patch as colored tags."""
        if not patch or not patch.labels:
            self._safe_addstr(y, 2, "(no labels)", self._dim())
            return
        x = 2
        for label in patch.labels:
            dim = LABEL_META.get(label, ("?", ""))[0]
            if dim == "req":
                attr = self._cp("info")
            elif dim == "prov":
                attr = self._cp("accent")
            elif dim == "aff":
