def load_patches():
    """Load built-in patches and any external patches from patches.d/."""
    patches = list(BUILTIN_PATCHES)
    if EXTERNAL_PATCHES_DIR.is_dir():
        for pf in sorted(EXTERNAL_PATCHES_DIR.glob("*.json")):
            try:
                data = json.loads(pf.read_text())
                patch_list = data if isinstance(data, list) else [data]
                for pd in patch_list:
                    mods = [
                        Modification(
                            file=m["file"],
                            search=m["search"],
                            replace=m["replace"],
                            description=m.get("description", ""),
                        )
                        for m in pd.get("modifications", [])
                    ]
                    patches.append(
                        Patch(
                            id=pd["id"],
                            name=pd["name"],
                            category=pd.get("category", "uncategorized"),
                            description=pd.get("description", ""),
                            modifications=mods,
                        )
                    )
            except (json.JSONDecodeError, KeyError) as e:
                print(f"Warning: skipping {pf.name}: {e}", file=sys.stderr)
    return patches


# ─── Patch Operations ───────────────────────────────────────────────────────

def detect_patch_state(asar_path, patch):
    """Detect if a patch is applied. Returns 'applied', 'not_applied', or 'unknown'."""
    try:
        header, fds = read_asar_header(asar_path)
    except Exception:
        return "unknown"

    any_file_found = False
    for mod in patch.modifications:
        matching_files = find_asar_files(header, mod.file)
        if not matching_files:
            continue
        any_file_found = True
        for fpath in matching_files:
            content = read_asar_file(asar_path, fpath)
            if content is None:
                continue
            text = content.decode("utf-8", errors="replace")
            if re.search(mod.search, text):
                return "not_applied"
    return "applied" if any_file_found else "unknown"


def apply_modification(extracted_dir, mod):
    """Apply a single modification to the extracted directory. Returns replacement count."""
    count = 0
    for root, dirs, files in os.walk(extracted_dir):
        for fname in sorted(files):
            full = os.path.join(root, fname)
            rel = os.path.relpath(full, extracted_dir)
            if fnmatch.fnmatch(rel, mod.file):
                with open(full, "r", errors="replace") as f:
                    content = f.read()
                new_content, n = re.subn(mod.search, mod.replace, content)
                if n > 0:
                    with open(full, "w") as f:
                        f.write(new_content)
                    count += n
    return count


def apply_patch(extracted_dir, patch):
    """Apply all modifications of a patch. Returns total replacement count."""
    total = 0
    for mod in patch.modifications:
        total += apply_modification(extracted_dir, mod)
    return total


# ─── App Operations ─────────────────────────────────────────────────────────

def get_paths(app_path):
    """Get all relevant paths for the app bundle."""
    return {
        "app": app_path,
        "resources": os.path.join(app_path, "Contents", "Resources"),
        "asar": os.path.join(app_path, "Contents", "Resources", "app.asar"),
        "asar_orig": os.path.join(
            app_path, "Contents", "Resources", "app.asar.orig"
        ),
        "asar_unpacked": os.path.join(
            app_path, "Contents", "Resources", "app.asar.unpacked"
        ),
        "plist": os.path.join(app_path, "Contents", "Info.plist"),
        "frameworks": os.path.join(app_path, "Contents", "Frameworks"),
    }


def quit_app(app_path):
    """Quit the app if running. Returns True if killed or not running."""
    proc_name = os.path.basename(app_path).replace(".app", "")
    result = subprocess.run(
        ["killall", proc_name], capture_output=True, text=True
    )
    if result.returncode == 0:
        import time

        time.sleep(1)
        return True
    return True


def ensure_original(paths):
    """Ensure a pristine backup of the original asar exists."""
    asar = paths["asar"]
    orig = paths["asar_orig"]

    if not os.path.exists(asar):
        raise FileNotFoundError(f"app.asar not found at {asar}")

    if not os.path.exists(orig):
        shutil.copy2(asar, orig)
        return True
    return False


def update_asar_hash(plist_path, asar_hash):
    """Update the ElectronAsarIntegrity hash in Info.plist."""
    import plistlib

    with open(plist_path, "rb") as f:
        plist = plistlib.load(f)
    if "ElectronAsarIntegrity" not in plist:
        plist["ElectronAsarIntegrity"] = {}
    if "Resources/app.asar" not in plist["ElectronAsarIntegrity"]:
        plist["ElectronAsarIntegrity"]["Resources/app.asar"] = {
            "algorithm": "SHA256",
            "hash": asar_hash,
        }
    else:
        plist["ElectronAsarIntegrity"]["Resources/app.asar"]["hash"] = asar_hash
    with open(plist_path, "wb") as f:
        plistlib.dump(plist, f)


def resign_app(app_path):
    """Re-sign the app with ad-hoc signature and proper entitlements."""
    frameworks = os.path.join(app_path, "Contents", "Frameworks")
    codex_fw = os.path.join(frameworks, "Codex Framework.framework")
    sparkle_fw = os.path.join(frameworks, "Sparkle.framework")

    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".plist", delete=False
    ) as f:
        f.write(APP_ENTITLEMENTS)
        app_ents = f.name
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".plist", delete=False
    ) as f:
        f.write(FW_ENTITLEMENTS)
        fw_ents = f.name

    try:
        if os.path.exists(codex_fw):
            subprocess.run(
                ["codesign", "--force", "--sign", "-", "--entitlements", fw_ents, codex_fw],
                capture_output=True, text=True, check=True,
            )
        if os.path.exists(sparkle_fw):
            subprocess.run(
                ["codesign", "--force", "--sign", "-", sparkle_fw],
                capture_output=True, text=True, check=False,
            )
        subprocess.run(
            ["codesign", "--force", "--sign", "-", "--entitlements", app_ents, app_path],
            capture_output=True, text=True, check=True,
        )
    finally:
        os.unlink(app_ents)
        os.unlink(fw_ents)


def verify_signature(app_path):
    """Verify the app's code signature. Returns (bool, message)."""
    result = subprocess.run(
        ["codesign", "--verify", "--verbose", app_path],
        capture_output=True, text=True,
    )
    if result.returncode == 0:
        return True, "valid"
    return False, result.stderr.strip()


# ─── State Management ───────────────────────────────────────────────────────

def load_state():
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except json.JSONDecodeError:
            pass
    return {}


def save_state(state):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(state, indent=2))


# ─── Commit Logic ───────────────────────────────────────────────────────────

def commit_changes(paths, patches_to_apply, progress_cb=None):
    """Extract original, apply selected patches, repack, install, and sign.

    Args:
        paths: dict from get_paths()
        patches_to_apply: list of Patch objects to apply
        progress_cb: optional callback(step_name) for progress updates

    Returns:
        (success: bool, message: str)
    """
    def report(msg):
        if progress_cb:
            progress_cb(msg)

    try:
        report("Quitting app if running...")
        quit_app(paths["app"])

        report("Ensuring original backup...")
        ensure_original(paths)

        with tempfile.TemporaryDirectory(prefix="codex-pm-") as tmpdir:
            extracted = os.path.join(tmpdir, "extracted")
            report("Extracting original asar...")
            unpacked_paths = extract_asar(
                paths["asar_orig"], extracted,
                unpacked_dir=paths["asar_unpacked"],
            )

            for patch in patches_to_apply:
                report(f"Applying: {patch.name}...")
                count = apply_patch(extracted, patch)
                report(f"  → {count} replacement(s)")

            patched_asar = os.path.join(tmpdir, "app-patched.asar")
            report("Packing patched asar...")
            pack_asar(extracted, patched_asar, unpacked_paths=unpacked_paths)

            new_hash = sha256_file(patched_asar)
            report(f"New asar hash: {new_hash[:16]}...")

            report("Installing patched asar...")
            shutil.copy2(patched_asar, paths["asar"])

            report("Updating integrity hash in Info.plist...")
            update_asar_hash(paths["plist"], new_hash)

            report("Re-signing Codex Framework...")
            report("Re-signing Sparkle Framework...")
            report("Re-signing main app...")
            resign_app(paths["app"])

            report("Verifying signature...")
            ok, msg = verify_signature(paths["app"])
            if not ok:
                report(f"WARNING: Signature verification failed: {msg}")
            else:
                report("Signature verified ✓")

            state = load_state()
            state["installed_hash"] = new_hash
            state["applied_patches"] = [p.id for p in patches_to_apply]
            save_state(state)

            report("Done!")
            return True, "Changes committed successfully"

    except Exception as e:
        return False, str(e)


