_v = "│"       # light vertical
_TL = "┏"     # top-left
_TR = "┓"     # top-right
_BL = "┗"     # bottom-left
_BR = "┛"     # bottom-right
_LT = "┣"     # left tee
_RT = "┫"     # right tee
_DOT = "●"
_CIRC = "○"
_TRI = "▸"
_ARR_R = "→"
_CHECK = "✓"
_CROSS = "✗"


class PatchManagerTUI:
    VIEWS = ("list", "detail", "preview", "commit")

    def __init__(self, stdscr, patches, states, paths):
        self.stdscr = stdscr
        self.patches = patches
        self.states = states
        self.paths = paths
        self.view = "list"
        self.cursor = 0
        self.scroll = 0
        self.detail_patch = None
        self.detail_scroll = 0
        self.desired = {
            p.id: self.states.get(p.id) == "applied" for p in patches
        }
        self.commit_log = []
        self.commit_done = False
        self.commit_success = False
        self.message = None
        self.message_age = 0

    @property
    def pending_apply(self):
        return [
            p for p in self.patches
            if self.desired.get(p.id, False)
            and self.states.get(p.id) != "applied"
        ]

    @property
    def pending_revert(self):
        return [
            p for p in self.patches
            if not self.desired.get(p.id, False)
            and self.states.get(p.id) == "applied"
        ]

    @property
    def has_pending(self):
        return bool(self.pending_apply or self.pending_revert)

    def abort_pending(self):
        """Discard all pending toggles: reset desired selection to current state."""
        for p in self.patches:
            self.desired[p.id] = self.states.get(p.id) == "applied"

    def run(self):
        try:
            curses.curs_set(0)
        except curses.error:
            pass
        self._init_colors()
        while True:
            self._draw()
            key = self.stdscr.getch()
            if key == ord("q") or key == 27:
                if self.view == "list":
                    break
                elif self.view == "commit" and not self.commit_done:
                    pass  # can't quit mid-commit
                else:
                    self.view = "list"
                    self._reset_view_state()
            elif self.view == "list":
                self._handle_list_key(key)
            elif self.view == "detail":
                self._handle_detail_key(key)
            elif self.view == "preview":
                self._handle_preview_key(key)
            elif self.view == "commit":
                if self.commit_done:
                    self._reset_view_state()
                    self.view = "list"
                    for p in self.patches:
                        self.states[p.id] = detect_patch_state(
                            self.paths["asar"], p
                        )
                        self.desired[p.id] = self.states[p.id] == "applied"

    def _reset_view_state(self):
        self.commit_log = []
        self.commit_done = False
        self.commit_success = False
        self.detail_scroll = 0

    def _init_colors(self):
        # Degrade gracefully to monochrome when the terminal lacks color
        # support (some PTYs/terminfo entries report COLORS=0 / COLOR_PAIRS=-1).
        if not curses.has_colors() or curses.COLORS < 1:
            return
        try:
            curses.start_color()
        except curses.error:
            return
        try:
            curses.use_default_colors()
            bg = -1
        except curses.error:
            bg = curses.COLOR_BLACK

        p = _CP
        cp = curses.init_pair
        try:
            cp(p["title"],     curses.COLOR_CYAN,    bg)
            cp(p["subtitle"],  curses.COLOR_CYAN,    bg)
            cp(p["dim"],       curses.COLOR_WHITE,   bg)  # +A_DIM for gray
            cp(p["applied"],   curses.COLOR_GREEN,   bg)
            cp(p["pending"],   curses.COLOR_YELLOW,  bg)
            cp(p["revert"],    curses.COLOR_RED,     bg)
            cp(p["info"],      curses.COLOR_CYAN,    bg)
            cp(p["accent"],    curses.COLOR_MAGENTA, bg)
            cp(p["success"],   curses.COLOR_GREEN,   bg)
            cp(p["error"],     curses.COLOR_RED,     bg)
            cp(p["border"],    curses.COLOR_WHITE,   bg)  # +A_DIM
            cp(p["keyhint"],   curses.COLOR_CYAN,    bg)
            cp(p["header"],    curses.COLOR_BLUE,    bg)
            cp(p["select"],    curses.COLOR_BLACK,   curses.COLOR_BLUE)
            cp(p["badge_on"],  curses.COLOR_BLACK,   curses.COLOR_GREEN)
            cp(p["badge_off"], curses.COLOR_BLACK,   curses.COLOR_WHITE)
            cp(p["badge_pend"],curses.COLOR_BLACK,   curses.COLOR_YELLOW)
            cp(p["badge_rev"], curses.COLOR_BLACK,   curses.COLOR_RED)
            cp(p["badge_unk"], curses.COLOR_BLACK,   curses.COLOR_WHITE)
        except curses.error:
            # Color pairs unavailable; render in monochrome. color_pair()
            # calls elsewhere return inert attributes in that case.
            pass

    def _cp(self, name, bright=False):
        """Get color attribute for a named pair, optionally brightened."""
        attr = curses.color_pair(_CP[name])
        if bright:
            attr |= curses.A_BOLD
        return attr

    def _dim(self, name="default"):
        """Get dimmed color attribute."""
        return curses.color_pair(_CP[name]) | curses.A_DIM

    def _safe_addstr(self, y, x, text, attr=0):
        h, w = self.stdscr.getmaxyx()
        if y < 0 or y >= h or x >= w:
            return
        text = text[: max(0, w - x - 1)]
        if text:
            try:
                self.stdscr.addstr(y, x, text, attr)
            except curses.error:
                pass

    def _hline(self, y, x, length, heavy=False):
        """Draw a horizontal line."""
        char = _H if heavy else _h
        self._safe_addstr(y, x, char * length, self._dim("border"))

    def _draw(self):
        self.stdscr.erase()
        h, w = self.stdscr.getmaxyx()
        if h < 12 or w < 64:
            self._safe_addstr(0, 0, "Terminal too small (need 64×12+)")
            return
        if self.view == "list":
            self._draw_list()
        elif self.view == "detail":
            self._draw_detail()
        elif self.view == "preview":
            self._draw_preview()
        elif self.view == "commit":
            self._draw_commit()
        self.stdscr.refresh()

    # ── List View ──

    def _draw_list(self):
        h, w = self.stdscr.getmaxyx()

        # Header
        self._safe_addstr(0, 1, " Codex Desktop Patch Manager ",
                          self._cp("title", bright=True))
        self._hline(1, 0, w, heavy=True)

        # App path
        app_short = self.paths["app"]
        if len(app_short) > w - 12:
            app_short = "…" + app_short[-(w - 14):]
        self._safe_addstr(2, 2, "App:", self._dim())
        self._safe_addstr(2, 7, app_short, self._cp("subtitle"))

        # Column header
        y = 4
        self._safe_addstr(y, 2, "St", self._cp("header", bright=True) | curses.A_UNDERLINE)
        self._safe_addstr(y, 6, "Patch", self._cp("header", bright=True) | curses.A_UNDERLINE)
        cat_x = max(w - 22, 40)
        self._safe_addstr(y, cat_x, "Category", self._cp("header", bright=True) | curses.A_UNDERLINE)
        y += 1
        self._hline(y, 1, w - 2)
        y += 1

        # Scroll logic
        visible = h - y - 4
        if self.cursor < self.scroll:
            self.scroll = self.cursor
        elif self.cursor >= self.scroll + visible:
            self.scroll = self.cursor - visible + 1

        # Patch rows
        for i, patch in enumerate(self.patches):
            if i < self.scroll:
                continue
            if i >= self.scroll + visible:
                break
            if y >= h - 4:
                break

            state = self.states.get(patch.id, "unknown")
            desired = self.desired.get(patch.id, False)
            is_applied = state == "applied"
            is_selected = i == self.cursor

            # Status badge
            if is_applied and desired:
                badge = " ON "
                badge_attr = curses.color_pair(_CP["badge_on"])
            elif not is_applied and not desired:
                badge = "off "
                badge_attr = curses.color_pair(_CP["badge_off"]) | curses.A_DIM
            elif is_applied and not desired:
                badge = "rev "
                badge_attr = curses.color_pair(_CP["badge_rev"])
            else:
                badge = "add "
                badge_attr = curses.color_pair(_CP["badge_pend"])

            # Cursor marker
            marker = _TRI if is_selected else "  "
            marker_attr = self._cp("accent", bright=True) if is_selected else 0

            # Name color
            if is_applied and desired:
                name_attr = self._cp("applied", bright=True)
            elif is_applied and not desired:
                name_attr = self._cp("revert")
            elif not is_applied and desired:
                name_attr = self._cp("pending", bright=True)
            else:
                name_attr = 0

            # Category color
            cat_attr = self._cp("accent")

            # Apply selection highlight
            if is_selected:
                badge_attr = curses.color_pair(_CP["select"])
                marker_attr = curses.color_pair(_CP["select"]) | curses.A_BOLD
                name_attr = curses.color_pair(_CP["select"]) | curses.A_BOLD
                cat_attr = curses.color_pair(_CP["select"])

            self._safe_addstr(y, 0, marker, marker_attr)
            self._safe_addstr(y, 3, badge, badge_attr)
            # Truncate name if too long
            name_max = cat_x - 9
            name = patch.name[:name_max]
            self._safe_addstr(y, 8, name, name_attr)
            self._safe_addstr(y, cat_x, patch.category, cat_attr)
            y += 1

        # Footer
        fy = h - 3
        self._hline(fy, 1, w - 2)
        fy += 1

        # Key hints — color-coded by action type
        hints = [
            ("↑↓", self._dim()),
            (" Navigate  ", 0),
            ("Space", self._cp("keyhint", bright=True)),
            (" Toggle  ", 0),
            ("Enter", self._cp("keyhint", bright=True)),
            (" Details  ", 0),
            ("P", self._cp("keyhint", bright=True)),
            (" Preview  ", 0),
            ("A", self._cp("revert", bright=True) if self.has_pending else self._dim()),
            (" Abort  ", 0),
            ("C", self._cp("pending", bright=True) if self.has_pending else self._dim()),
            (" Commit", 0),
        ]
        x = 2
        for text, attr in hints:
            self._safe_addstr(fy, x, text, attr)
            x += len(text)
        self._safe_addstr(fy, w - 7, "Q Quit", self._dim())

        # Status line
        applied_count = sum(1 for p in self.patches if self.states.get(p.id) == "applied")
        pending = len(self.pending_apply) + len(self.pending_revert)
        parts = [
            (f" {applied_count}", self._cp("applied", bright=True)),
            (f"/{len(self.patches)} applied", self._dim()),
        ]
        if pending:
            parts.append((f"  {_DOT} ", self._cp("pending", bright=True)))
            parts.append((f"{pending} pending", self._cp("pending", bright=True)))
        x = 2
        for text, attr in parts:
            self._safe_addstr(h - 1, x, text, attr)
            x += len(text)

    # ── Detail View ──

    def _draw_detail(self):
        h, w = self.stdscr.getmaxyx()
        patch = self.detail_patch
        if not patch:
            self.view = "list"
            return

        y = 0
        # Title bar
        self._safe_addstr(y, 1, " Patch Details ", self._cp("title", bright=True))
        self._hline(y, 0, w, heavy=True)
        y += 2

        # Patch name
        name = patch.name[:w - 4]
        self._safe_addstr(y, 2, name, curses.A_BOLD)
        y += 1
        self._hline(y, 1, w - 2)
        y += 2

        # Metadata fields
        state = self.states.get(patch.id, "unknown")
        desired = self.desired.get(patch.id, False)

        fields = [
            ("ID", patch.id, self._cp("info")),
            ("Category", patch.category, self._cp("accent")),
        ]
        for label, value, val_attr in fields:
            self._safe_addstr(y, 4, f"{label}:", self._dim())
            self._safe_addstr(y, 14, value, val_attr)
            y += 1

        # Status field with badge
        self._safe_addstr(y, 4, "Status:", self._dim())
        if state == "applied":
            if desired:
                self._safe_addstr(y, 14, f" {_CHECK} APPLIED ", curses.color_pair(_CP["badge_on"]))
            else:
                self._safe_addstr(y, 14, f" ↻ PENDING REVERT ", curses.color_pair(_CP["badge_rev"]))
        elif state == "not_applied":
            if desired:
                self._safe_addstr(y, 14, f" + PENDING APPLY ", curses.color_pair(_CP["badge_pend"]))
            else:
                self._safe_addstr(y, 14, f" {_CIRC} NOT APPLIED ", curses.color_pair(_CP["badge_off"]) | curses.A_DIM)
        else:
            self._safe_addstr(y, 14, " ? UNKNOWN ", curses.color_pair(_CP["badge_unk"]))
        y += 2

        # Description section
        self._safe_addstr(y, 2, " Description ", self._cp("header", bright=True))
        y += 1
        self._hline(y, 1, w - 2)
        y += 1
        desc_y_start = y
        desc_lines = []
        for line in patch.description.split("\n"):
            for wrapped in self._wrap(line, w - 8):
                desc_lines.append(wrapped)

        max_desc = h - y - 10
        for i, line in enumerate(desc_lines):
            if i < self.detail_scroll:
                continue
            if i >= self.detail_scroll + max_desc:
                break
            self._safe_addstr(y, 4, line)
            y += 1
        y += 1

        # Modifications section
        self._safe_addstr(y, 2, f" Modifications ({len(patch.modifications)}) ",
                          self._cp("header", bright=True))
        y += 1
        self._hline(y, 1, w - 2)
        y += 1

        for i, mod in enumerate(patch.modifications, 1):
            if y >= h - 5:
                break
            self._safe_addstr(y, 4, f"{i}.", self._cp("accent"))
            self._safe_addstr(y, 7, mod.file[:w - 10], self._cp("info"))
            y += 1
            if y >= h - 5:
                break
            search_display = mod.search if len(mod.search) < w - 14 else mod.search[:w - 17] + "…"
            replace_display = mod.replace if len(mod.replace) < 10 else mod.replace[:10]
            self._safe_addstr(y, 7, f"{search_display}", self._cp("revert"))
            self._safe_addstr(y, 7 + len(search_display) + 1, _ARR_R, self._dim())
            self._safe_addstr(y, 7 + len(search_display) + 3, replace_display, self._cp("applied", bright=True))
            y += 1
            if y >= h - 5:
                break
            if mod.description:
                self._safe_addstr(y, 9, mod.description, self._dim())
                y += 1
            y += 1

        # Footer
        fy = h - 3
        self._hline(fy, 1, w - 2)
        fy += 1
        hints = [
            ("Enter/ESC", self._cp("keyhint", bright=True)),
            (" Back  ", 0),
            ("Space", self._cp("keyhint", bright=True)),
            (" Toggle  ", 0),
            ("P", self._cp("keyhint", bright=True)),
            (" Preview  ", 0),
            ("A", self._cp("revert", bright=True) if self.has_pending else self._dim()),
            (" Abort  ", 0),
            ("C", self._cp("pending", bright=True) if self.has_pending else self._dim()),
            (" Commit", 0),
        ]
        x = 2
        for text, attr in hints:
            self._safe_addstr(fy, x, text, attr)
            x += len(text)
        self._safe_addstr(fy, w - 7, "Q Quit", self._dim())

    # ── Preview View ──

    def _draw_preview(self):
        h, w = self.stdscr.getmaxyx()
        y = 0

        # Title
        self._safe_addstr(y, 1, " Preview Changes ", self._cp("title", bright=True))
        self._hline(y, 0, w, heavy=True)
        y += 2

        to_apply = self.pending_apply
        to_revert = self.pending_revert

        # Apply section
        if to_apply:
            self._safe_addstr(y, 2, f" Will Apply ({len(to_apply)}) ",
                              self._cp("header", bright=True))
            y += 1
            self._hline(y, 1, w - 2)
            y += 1
            for p in to_apply:
                if y >= h - 6:
                    break
                self._safe_addstr(y, 4, f"+ {p.id}", self._cp("applied", bright=True))
                y += 1
                self._safe_addstr(y, 6, p.short_desc[:w - 8], self._dim())
                y += 1
            y += 1

        # Revert section
        if to_revert:
            self._safe_addstr(y, 2, f" Will Revert ({len(to_revert)}) ",
                              self._cp("header", bright=True))
            y += 1
            self._hline(y, 1, w - 2)
            y += 1
            for p in to_revert:
                if y >= h - 6:
                    break
                self._safe_addstr(y, 4, f"- {p.id}", self._cp("revert", bright=True))
                y += 1
                self._safe_addstr(y, 6, p.short_desc[:w - 8], self._dim())
                y += 1
            y += 1

        # Empty state
        if not to_apply and not to_revert:
            self._safe_addstr(y, 4, "No changes pending.", self._dim())
            self._safe_addstr(y + 1, 4, "Toggle patches with Space to stage changes.", self._dim())
            y += 3

        # Summary
        if y < h - 4:
            self._hline(y, 1, w - 2)
            y += 1
            summary = f" {len(to_apply)} to apply  {_V}  {len(to_revert)} to revert "
            self._safe_addstr(y, 2, summary, self._cp("pending", bright=True) if (to_apply or to_revert) else self._dim())
            y += 2

        # Footer
        fy = h - 2
        if self.has_pending:
            self._safe_addstr(fy, 2, "C", self._cp("pending", bright=True))
            self._safe_addstr(fy, 3, " Commit   ", 0)
            self._safe_addstr(fy, 14, "A", self._cp("revert", bright=True))
            self._safe_addstr(fy, 15, " Abort   ", 0)
        self._safe_addstr(fy, 26, "Any key", self._cp("keyhint", bright=True))
        self._safe_addstr(fy, 34, " Back", 0)
        self._safe_addstr(fy, w - 7, "Q Quit", self._dim())

    # ── Commit View ──

    def _draw_commit(self):
        h, w = self.stdscr.getmaxyx()
        y = 0

        if self.commit_done:
            # Success or failure header
            if self.commit_success:
                self._safe_addstr(y, 1, f" {_CHECK} Commit Complete ",
                                  self._cp("success", bright=True))
            else:
                self._safe_addstr(y, 1, f" {_CROSS} Commit Failed ",
                                  self._cp("error", bright=True))
        else:
            self._safe_addstr(y, 1, " Committing Changes ",
                             self._cp("pending", bright=True))
        self._hline(y, 0, w, heavy=True)
        y += 2

        # Log entries
        for entry in self.commit_log:
            if y >= h - 3:
                break
            if entry.startswith("Done!"):
                self._safe_addstr(y, 2, f"{_CHECK} {entry}", self._cp("success", bright=True))
            elif entry.startswith("ERROR"):
                self._safe_addstr(y, 2, f"{_CROSS} {entry}", self._cp("error", bright=True))
            elif entry.startswith("WARNING"):
                self._safe_addstr(y, 2, f"⚠ {entry}", self._cp("pending"))
            elif entry.startswith("Signature verified"):
                self._safe_addstr(y, 2, f"{_CHECK} {entry}", self._cp("applied", bright=True))
            elif entry.startswith("  →"):
                self._safe_addstr(y, 4, entry, self._cp("info"))
            elif entry.startswith("Applying:"):
                self._safe_addstr(y, 2, entry, self._cp("accent"))
            elif entry.startswith("New asar hash"):
                self._safe_addstr(y, 2, entry, self._dim())
            else:
                self._safe_addstr(y, 2, entry, self._dim())
            y += 1

        if self.commit_done:
            y += 1
            if y < h - 1:
                self._safe_addstr(y, 2, "Press any key to continue...", self._dim())

    # ── Helpers ──

    def _wrap(self, text, width):
        if not text:
            return [""]
        words = text.split()
        lines = []
        current = ""
        for word in words:
            if len(current) + len(word) + 1 <= width:
                current = f"{current} {word}".strip()
            else:
                if current:
                    lines.append(current)
                current = word
        if current:
            lines.append(current)
        return lines

    # ── Key Handlers ──

    def _handle_list_key(self, key):
        if key in (curses.KEY_UP, ord("k")):
            self.cursor = max(0, self.cursor - 1)
        elif key in (curses.KEY_DOWN, ord("j")):
            self.cursor = min(len(self.patches) - 1, self.cursor + 1)
        elif key == ord(" "):
            if self.patches:
                patch = self.patches[self.cursor]
                self.desired[patch.id] = not self.desired.get(patch.id, False)
        elif key in (ord("\n"), curses.KEY_ENTER):
            if self.patches:
                self.detail_patch = self.patches[self.cursor]
                self.detail_scroll = 0
                self.view = "detail"
        elif key == ord("a"):
            if self.has_pending:
                self.abort_pending()
        elif key == ord("p"):
            self.view = "preview"
        elif key == ord("c"):
            if self.has_pending:
                self.view = "commit"
                self.commit_log = []
                self.commit_done = False
                self._do_commit()

    def _handle_detail_key(self, key):
        if key in (curses.KEY_UP, ord("k")):
            self.detail_scroll = max(0, self.detail_scroll - 1)
        elif key in (curses.KEY_DOWN, ord("j")):
            self.detail_scroll += 1
        elif key == ord(" "):
            if self.detail_patch:
                pid = self.detail_patch.id
                self.desired[pid] = not self.desired.get(pid, False)
        elif key in (ord("\n"), curses.KEY_ENTER, 27):
            self.view = "list"
        elif key == ord("a"):
            if self.has_pending:
                self.abort_pending()
        elif key == ord("p"):
            self.view = "preview"
        elif key == ord("c"):
            if self.has_pending:
                self.view = "commit"
                self.commit_log = []
                self.commit_done = False
                self._do_commit()

    def _handle_preview_key(self, key):
        if key == ord("c") and self.has_pending:
            self.view = "commit"
            self.commit_log = []
            self.commit_done = False
            self._do_commit()
        elif key == ord("a") and self.has_pending:
            self.abort_pending()
            self.view = "list"
        else:
            self.view = "list"

    def _do_commit(self):
        patches_to_apply = [p for p in self.patches if self.desired.get(p.id, False)]
        self.commit_log = []

        def progress(msg):
            self.commit_log.append(msg)
            self._draw_commit()
            self.stdscr.refresh()

        success, message = commit_changes(self.paths, patches_to_apply, progress)
        self.commit_success = success
        if not success:
            self.commit_log.append(f"ERROR: {message}")
        self.commit_done = True
        self._draw_commit()
        self.stdscr.refresh()


# ─── CLI (non-interactive, colorized) ───────────────────────────────────────

def _state_symbol(state):
    """Return (symbol, color_code) for a patch state."""
    if state == "applied":
        return (_DOT, c.GREEN)
    elif state == "not_applied":
        return (_CIRC, c.B_BLACK)
    else:
        return ("?", c.YELLOW)


def cmd_list(patches, paths):
    """List all patches and their current state."""
    print()
    print(f"  {c.wrap(c.B_CYAN + c.BOLD, 'Codex Desktop Patch Manager')}")
    print(f"  {c.wrap(c.DIM, 'App:')} {c.wrap(c.CYAN, paths['app'])}")
    print()

    for patch in patches:
        state = detect_patch_state(paths["asar"], patch)
        symbol, color = _state_symbol(state)

        status_text = {
            "applied": c.wrap(c.GREEN + c.BOLD, "APPLIED"),
            "not_applied": c.wrap(c.B_BLACK, "not applied"),
            "unknown": c.wrap(c.YELLOW, "UNKNOWN"),
        }[state]

        print(f"  {c.wrap(color, symbol)}  {c.wrap(c.CYAN, patch.id)}")
        print(f"     {c.wrap(c.BOLD, patch.name)}")
        print(f"     {c.wrap(c.DIM, 'Category:')} {c.wrap(c.MAGENTA, patch.category)}  "
              f"{c.wrap(c.DIM, '·')}  {c.wrap(c.DIM, 'Status:')} {status_text}")
        print()


def cmd_apply(patches, paths, patch_ids):
    """Apply specified patches."""
    ensure_original(paths)
    selected = []
    for pid in patch_ids:
        patch = next((p for p in patches if p.id == pid), None)
        if not patch:
            print(f"{c.wrap(c.RED + c.BOLD, '✗')} Unknown patch: {pid}", file=sys.stderr)
            sys.exit(1)
        selected.append(patch)
    for p in patches:
        state = detect_patch_state(paths["asar"], p)
        if state == "applied" and p not in selected:
            selected.append(p)
    success, msg = commit_changes(paths, selected, lambda m: print(f"  {c.wrap(c.DIM, m)}"))
    if success:
        print(f"\n  {c.wrap(c.GREEN + c.BOLD, '✓')} {c.wrap(c.GREEN, msg)}")
    else:
        print(f"\n  {c.wrap(c.RED + c.BOLD, '✗')} {c.wrap(c.RED, msg)}", file=sys.stderr)
        sys.exit(1)


def cmd_revert(patches, paths, patch_ids):
    """Revert specified patches (or all)."""
    ensure_original(paths)
    if not patch_ids or "all" in patch_ids:
        to_revert = set(p.id for p in patches)
    else:
        to_revert = set(patch_ids)
    selected = [p for p in patches if p.id not in to_revert]
    success, msg = commit_changes(paths, selected, lambda m: print(f"  {c.wrap(c.DIM, m)}"))
    if success:
        print(f"\n  {c.wrap(c.GREEN + c.BOLD, '✓')} {c.wrap(c.GREEN, msg)}")
    else:
        print(f"\n  {c.wrap(c.RED + c.BOLD, '✗')} {c.wrap(c.RED, msg)}", file=sys.stderr)
        sys.exit(1)


def cmd_status(patches, paths):
    """Show brief status."""
    applied = 0
    for p in patches:
        state = detect_patch_state(paths["asar"], p)
        if state == "applied":
            applied += 1
            print(f"  {c.wrap(c.GREEN, _CHECK)} {c.wrap(c.CYAN, p.id)}")
    total = len(patches)
    summary = f"\n  {c.wrap(c.GREEN + c.BOLD, str(applied))}/{c.wrap(c.DIM, str(total))} patches applied"
    print(summary)


# ─── Install ────────────────────────────────────────────────────────────────

INSTALL_LINK_NAME = "codex-patch-manager"


def cmd_install():
    """Install codex-patch-manager into ~/.local/bin and ensure PATH activation."""
    LOCAL_BIN.mkdir(parents=True, exist_ok=True)

    # Ensure ~/.local/bin/env exists and activates ~/.local/bin on PATH.
    # This file is sourced by ~/.profile and ~/.zshenv.  If it already
    # exists (e.g. created by another tool), leave it untouched.
    if not LOCAL_BIN_ENV.exists():
        LOCAL_BIN_ENV.write_text(LOCAL_BIN_ENV_CONTENT)
        LOCAL_BIN_ENV.chmod(0o644)
        print(f"  {c.wrap(c.DIM, 'created')} {c.wrap(c.CYAN, str(LOCAL_BIN_ENV))}")
    else:
        print(f"  {c.wrap(c.DIM, 'exists')}  {c.wrap(c.CYAN, str(LOCAL_BIN_ENV))}")

    if not LOCAL_BIN_ENV_FISH.exists():
        LOCAL_BIN_ENV_FISH.write_text(LOCAL_BIN_ENV_FISH_CONTENT)
        LOCAL_BIN_ENV_FISH.chmod(0o644)
        print(f"  {c.wrap(c.DIM, 'created')} {c.wrap(c.CYAN, str(LOCAL_BIN_ENV_FISH))}")
    else:
        print(f"  {c.wrap(c.DIM, 'exists')}  {c.wrap(c.CYAN, str(LOCAL_BIN_ENV_FISH))}")

    # Symlink the script into ~/.local/bin so updates to the repo copy
    # are picked up automatically.
    target = LOCAL_BIN / INSTALL_LINK_NAME
    script = SCRIPT_DIR / "codex-patch-manager"
    if target.is_symlink() or target.exists():
        target.unlink()
    target.symlink_to(script)
    target.chmod(0o755)
    print(f"  {c.wrap(c.DIM, 'linked')}  {c.wrap(c.CYAN, str(target))} {c.wrap(c.DIM, '->')} {c.wrap(c.CYAN, str(script))}")

    # Check whether ~/.local/bin is on PATH in the *current* shell.
    path_dirs = os.environ.get("PATH", "").split(":")
    on_path = str(LOCAL_BIN) in path_dirs
    if on_path:
        print(f"\n  {c.wrap(c.GREEN + c.BOLD, '✓')} Installed. {c.wrap(c.CYAN, INSTALL_LINK_NAME)} is on your PATH.")
        print(f"  Run {c.wrap(c.BOLD, 'codex-patch-manager')} from anywhere.")
    else:
        print(f"\n  {c.wrap(c.GREEN + c.BOLD, '✓')} Installed to {c.wrap(c.CYAN, str(LOCAL_BIN))}.")
        print(f"  {c.wrap(c.YELLOW, '⚠')} {c.wrap(c.BOLD, str(LOCAL_BIN))} is not on your PATH in this shell.")
        print(f"  It will be activated in new shells via {c.wrap(c.CYAN, '~/.local/bin/env')},")
        print(f"  which is sourced by {c.wrap(c.CYAN, '~/.profile')} and {c.wrap(c.CYAN, '~/.zshenv')}.")
        print(f"  For this shell: {c.wrap(c.BOLD, 'source ~/.local/bin/env')}")




# ─── Main ───────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Codex Desktop Patch Manager",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Run without arguments to launch the interactive TUI.\n"
            "Add patches to patches.d/*.json for extensibility."
        ),
    )
    parser.add_argument("--app", default=DEFAULT_APP, help="Path to ChatGPT.app")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("list", help="List patches and their states")
    sub.add_parser("status", help="Brief status of applied patches")
    p_apply = sub.add_parser("apply", help="Apply patches")
    p_apply.add_argument("patches", nargs="+", help="Patch IDs to apply")
    p_revert = sub.add_parser("revert", help="Revert patches")
    p_revert.add_argument(
        "patches", nargs="*", default=["all"], help="Patch IDs to revert (or 'all')"
    )
    sub.add_parser("tui", help="Launch interactive TUI")
    sub.add_parser("install", help="Install to ~/.local/bin and ensure PATH activation")

    args = parser.parse_args()

    if args.command == "install":
        cmd_install()
        return

    paths = get_paths(args.app)

    if not os.path.exists(paths["asar"]):
        print(f"Error: {paths['asar']} not found", file=sys.stderr)
        sys.exit(1)

    patches = load_patches()

    if args.command == "list":
        cmd_list(patches, paths)
    elif args.command == "status":
        cmd_status(patches, paths)
    elif args.command == "apply":
        cmd_apply(patches, paths, args.patches)
    elif args.command == "revert":
        cmd_revert(patches, paths, args.patches)
    elif args.command == "tui":
        _run_tui(patches, paths)
    else:
        _run_tui(patches, paths)


def _run_tui(patches, paths):
    states = {}
    for p in patches:
        states[p.id] = detect_patch_state(paths["asar"], p)

    def tui_main(stdscr):
        ui = PatchManagerTUI(stdscr, patches, states, paths)
        ui.run()

    try:
        curses.wrapper(tui_main)
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()