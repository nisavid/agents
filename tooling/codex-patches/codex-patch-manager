# ─── Asar Format (pure Python, no dependencies) ─────────────────────────────

def read_asar_header(filepath):
    """Read asar header, returning (json_header_dict, file_data_start_offset)."""
    with open(filepath, "rb") as f:
        head = f.read(20)
        if len(head) < 16:
            raise ValueError("File too small to be an asar archive")
        if head[8] == 0x7B:
            json_offset = 8
            json_size = struct.unpack("<I", head[4:8])[0]
        elif head[16] == 0x7B:
            json_offset = 16
            json_size = struct.unpack("<I", head[12:16])[0]
        else:
            raise ValueError(
                f"Cannot detect asar header format "
                f"(byte 8=0x{head[8]:02x}, byte 16=0x{head[16]:02x})"
            )
        f.seek(json_offset)
        header = json.loads(f.read(json_size).decode("utf-8"))
        padded = math.ceil(json_size / 4) * 4
        file_data_start = json_offset + padded
        return header, file_data_start


def read_asar_file(filepath, file_path):
    """Read a single file from the asar by its internal path. Returns bytes or None."""
    header, fds = read_asar_header(filepath)
    node = header
    for part in file_path.split("/"):
        if not isinstance(node, dict) or "files" not in node:
            return None
        node = node["files"].get(part)
        if node is None:
            return None
    if not isinstance(node, dict) or "offset" not in node:
        return None
    with open(filepath, "rb") as f:
        f.seek(int(node["offset"]) + fds)
        return f.read(node["size"])


def find_asar_files(header, glob_pattern):
    """Find all file paths in the asar header matching a glob pattern."""
    results = []

    def walk(node, path):
        if not isinstance(node, dict):
            return
        if "files" in node:
            for name, child in node["files"].items():
                walk(child, f"{path}/{name}" if path else name)
        elif "offset" in node and path:
            if fnmatch.fnmatch(path, glob_pattern):
                results.append(path)

    walk(header, "")
    return sorted(results)


def extract_asar(asar_path, dest_dir, unpacked_dir=None):
    """Extract an asar archive to a directory.

    Packed files (those with an "offset") are read from the asar binary.
    Unpacked files (those with "unpacked": true and no offset) are copied
    from the sibling ``unpacked_dir`` (defaults to ``asar_path + ".unpacked"``).

    Returns a set of relative paths that are unpacked.  This set must be
    passed to :func:`pack_asar` so the repacked header preserves the
    "unpacked": true flag for those entries.
    """
    header, fds = read_asar_header(asar_path)
    os.makedirs(dest_dir, exist_ok=True)
    if unpacked_dir is None:
        unpacked_dir = asar_path + ".unpacked"
    unpacked_paths = set()

    def extract_node(node, current_path, rel_path):
        if not isinstance(node, dict):
            return
        if "files" in node:
            os.makedirs(current_path, exist_ok=True)
            for name, child in node["files"].items():
                child_rel = f"{rel_path}/{name}" if rel_path else name
                extract_node(child, os.path.join(current_path, name), child_rel)
        elif "offset" in node:
            os.makedirs(os.path.dirname(current_path), exist_ok=True)
            with open(asar_path, "rb") as f:
                f.seek(int(node["offset"]) + fds)
                data = f.read(node["size"])
            with open(current_path, "wb") as out:
                out.write(data)
        elif node.get("unpacked"):
            unpacked_paths.add(rel_path)
            src_file = os.path.join(unpacked_dir, rel_path)
            if os.path.exists(src_file):
                os.makedirs(os.path.dirname(current_path), exist_ok=True)
                shutil.copy2(src_file, current_path)

    extract_node(header, dest_dir, "")
    return unpacked_paths


def _compute_integrity(data):
    """Compute asar integrity metadata for file content."""
    block_size = 4 * 1024 * 1024
    blocks = []
    for i in range(0, len(data), block_size):
        block = data[i : i + block_size]
        blocks.append(
            base64.b64encode(hashlib.sha256(block).digest()).decode("ascii")
        )
    return {
        "algorithm": "SHA256",
        "hash": base64.b64encode(hashlib.sha256(data).digest()).decode("ascii"),
        "blockSize": block_size,
        "blocks": blocks,
    }


def pack_asar(src_dir, dest_path, unpacked_paths=None):
    """Pack a directory into an asar archive.

    Files whose relative paths appear in ``unpacked_paths`` are marked
    "unpacked": true in the header (with size and integrity) but are
    excluded from the binary payload.  Their data must already exist in a
    sibling ``<dest_path>.unpacked/`` directory — pack does not create or
    modify that directory.
    """
    if unpacked_paths is None:
        unpacked_paths = set()
    file_table = {}
    file_chunks = []
    current_offset = 0

    def add_entry(full_path, name, table, rel_path):
        nonlocal current_offset
        if os.path.isdir(full_path):
            sub_table = {}
            for entry in sorted(os.listdir(full_path)):
                child_rel = f"{rel_path}/{entry}" if rel_path else entry
                add_entry(os.path.join(full_path, entry), entry, sub_table, child_rel)
            if sub_table:
                table[name] = {"files": sub_table}
        elif os.path.isfile(full_path):
            with open(full_path, "rb") as f:
                data = f.read()
            if rel_path in unpacked_paths:
                table[name] = {
                    "size": len(data),
                    "integrity": _compute_integrity(data),
                    "unpacked": True,
                }
            else:
                table[name] = {
                    "size": len(data),
                    "offset": str(current_offset),
                    "integrity": _compute_integrity(data),
                }
                file_chunks.append(data)
                current_offset += len(data)

    for entry in sorted(os.listdir(src_dir)):
        add_entry(os.path.join(src_dir, entry), entry, file_table, entry)

    header = {"files": file_table}
    json_bytes = json.dumps(header, separators=(",", ":")).encode("utf-8")
    json_size = len(json_bytes)
    padded_size = math.ceil(json_size / 4) * 4

    outer_size = 8 + padded_size
    inner_size = 4 + padded_size

    with open(dest_path, "wb") as f:
        f.write(struct.pack("<I", 4))
        f.write(struct.pack("<I", outer_size))
        f.write(struct.pack("<I", inner_size))
        f.write(struct.pack("<I", json_size))
        f.write(json_bytes)
        if padded_size > json_size:
            f.write(b"\x00" * (padded_size - json_size))
        for chunk in file_chunks:
            f.write(chunk)


def sha256_file(path):
    """Compute SHA256 hex digest of a file."""
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


