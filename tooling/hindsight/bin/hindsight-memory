BROKER_REQUEST = b'{"id":"health","jsonrpc":"2.0","method":"session_status","params":{}}\n'
BROKER_HEALTH_RESPONSE = {
    "jsonrpc": "2.0",
    "id": "health",
    "error": {"code": -32602, "message": "SCHEMA_INVALID"},
}
ENVIRONMENT_NAME = re.compile(r"[A-Z_][A-Z0-9_]{0,127}\Z")
MAX_SIGNAL_PID = (1 << 31) - 1


class BrokerProcessIdentity(NamedTuple):
    pid: int
    start_time: str | None
    shutdown_capability: str | None = None
    profile_set_digest: str | None = None


def read_json(path: str | Path) -> Any:
    return strict_json_loads(Path(path).read_text(encoding="utf-8"))


def _regular_file_digest(value: str | Path, label: str) -> str:
    path = Path(value)
    if not path.is_absolute():
        raise ApplyError(f"{label} path must be absolute")
    try:
        reject_symlink_components(path, label, allow_missing=False)
        flags = os.O_RDONLY | getattr(os, "O_CLOEXEC", 0) | getattr(os, "O_NOFOLLOW", 0)
        descriptor = os.open(path, flags)
        try:
            before = os.fstat(descriptor)
            validate_trusted_regular_file(before, label)
            artifact_hash = hashlib.sha256()
            while chunk := os.read(descriptor, 1024 * 1024):
                artifact_hash.update(chunk)
            after = os.fstat(descriptor)
        finally:
            os.close(descriptor)
        current = path.lstat()
    except FileEvidenceError as error:
        raise ApplyError(str(error)) from None
    except OSError:
        raise ApplyError(f"{label} is unavailable") from None
    if file_identity(before) != file_identity(after) or (
        current.st_dev, current.st_ino
    ) != (after.st_dev, after.st_ino):
        raise ApplyError(f"{label} changed while being read")
    return artifact_hash.hexdigest()


def _paths_overlap(candidate: str | Path, protected: list[str | Path]) -> bool:
    candidate_path = Path(candidate)
    if not candidate_path.is_absolute():
        raise ApplyError("rollback archive path must be absolute")
    candidate_resolved = candidate_path.resolve(strict=False)
    for value in protected:
        protected_path = Path(value)
        if candidate_resolved == protected_path.resolve(strict=False):
            return True
        try:
            if candidate_path.exists() and protected_path.exists() and os.path.samefile(candidate_path, protected_path):
                return True
        except OSError:
            raise ApplyError("migration archive identity is unavailable") from None
    return False


def _open_private_parent(path: Path) -> int:
    if not hasattr(os, "O_DIRECTORY") or not hasattr(os, "O_NOFOLLOW"):
        raise OSError("symlink-safe directory access is unavailable")
    flags = os.O_RDONLY | os.O_DIRECTORY | os.O_NOFOLLOW
    absolute = Path(os.path.abspath(path))
    if sys.platform == "darwin" and len(absolute.parts) > 1:
        aliases = {"var": ("private", "var"), "tmp": ("private", "tmp"), "etc": ("private", "etc")}
        replacement = aliases.get(absolute.parts[1])
        if replacement is not None:
            absolute = Path("/").joinpath(*replacement, *absolute.parts[2:])
    descriptor = os.open("/", flags)
    try:
        root_metadata = os.fstat(descriptor)
        if (
            not stat.S_ISDIR(root_metadata.st_mode)
            or root_metadata.st_uid != 0
            or stat.S_IMODE(root_metadata.st_mode) & 0o022
        ):
            raise OSError("private artifact root ancestry is untrusted")
        for component in absolute.parts[1:]:
            try:
                child = os.open(component, flags, dir_fd=descriptor)
            except FileNotFoundError:
                try:
                    os.mkdir(component, 0o700, dir_fd=descriptor)
                except FileExistsError:
                    pass
                else:
                    os.fsync(descriptor)
                child = os.open(component, flags, dir_fd=descriptor)
            metadata = os.fstat(child)
            if (
                not stat.S_ISDIR(metadata.st_mode)
                or metadata.st_uid not in {0, os.geteuid()}
                or (
                    stat.S_IMODE(metadata.st_mode) & 0o022
                    and not (
                        metadata.st_uid == 0
                        and metadata.st_mode & stat.S_ISVTX
                    )
                )
            ):
                os.close(child)
                raise OSError("private artifact parent ancestry is untrusted")
            os.close(descriptor)
            descriptor = child
        final_metadata = os.fstat(descriptor)
        if (
            final_metadata.st_uid != os.geteuid()
            or stat.S_IMODE(final_metadata.st_mode) & 0o077
        ):
            raise OSError("private artifact parent must be current-user-owned and private")
        return descriptor
    except Exception:
        os.close(descriptor)
        raise


def _directory_entry_identity(directory: int, name: str) -> tuple[int, int] | None:
    try:
        metadata = os.stat(name, dir_fd=directory, follow_symlinks=False)
    except FileNotFoundError:
        return None
    if not stat.S_ISREG(metadata.st_mode):
        raise OSError("private artifact destination must be a regular file")
    return metadata.st_dev, metadata.st_ino


def _atomic_rename(directory: int, source: str, target: str, flag: int) -> None:
    library = ctypes.CDLL(None, use_errno=True)
    function_name = "renameatx_np" if sys.platform == "darwin" else "renameat2"
    try:
        rename = getattr(library, function_name)
    except AttributeError as error:
        raise OSError("atomic conditional rename is unavailable") from error
    rename.argtypes = [
        ctypes.c_int,
        ctypes.c_char_p,
        ctypes.c_int,
        ctypes.c_char_p,
        ctypes.c_uint,
    ]
    rename.restype = ctypes.c_int
    if rename(
        directory,
        os.fsencode(source),
        directory,
        os.fsencode(target),
        flag,
    ) != 0:
        error_number = ctypes.get_errno()
        raise OSError(error_number, os.strerror(error_number), target)


def _commit_private_artifact(
    directory: int,
    temporary_name: str,
    target_name: str,
    expected_identity: tuple[int, int] | None,
) -> None:
    exclusive = 0x00000004 if sys.platform == "darwin" else 0x00000001
    exchange = 0x00000002
    if expected_identity is None:
        _atomic_rename(directory, temporary_name, target_name, exclusive)
        return

    new_identity = _directory_entry_identity(directory, temporary_name)
    if new_identity is None:
        raise OSError("private artifact temporary disappeared before commit")
    _atomic_rename(directory, temporary_name, target_name, exchange)
    try:
        displaced_identity = _directory_entry_identity(directory, temporary_name)
        if displaced_identity != expected_identity:
            raise OSError("private artifact destination changed during write")
    except Exception as error:
        try:
            _atomic_rename(directory, temporary_name, target_name, exchange)
            restored_identity = _directory_entry_identity(directory, target_name)
            restored_temporary = _directory_entry_identity(directory, temporary_name)
        except Exception as rollback_error:
            raise OSError(
                "private artifact exchange rollback is uncertain; preserving both entries"
            ) from rollback_error
        if restored_identity != expected_identity or restored_temporary != new_identity:
            raise OSError(
                "private artifact exchange rollback is uncertain; preserving both entries"
            ) from error
        raise
    os.unlink(temporary_name, dir_fd=directory)


def write_private(
    path: str | Path, value: Any, *, create_only: bool = False
) -> None:
    target = Path(path)
    if target.name in {"", ".", ".."}:
        raise OSError("private artifact destination name is invalid")
    directory = _open_private_parent(target.parent)
    descriptor = -1
    temporary_name: str | None = None
    temporary_identity: tuple[int, int] | None = None
    try:
        expected_identity = _directory_entry_identity(directory, target.name)
        if create_only and expected_identity is not None:
            raise FileExistsError(
                "private artifact destination already exists"
            )
        temporary_flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL | os.O_NOFOLLOW
        for _attempt in range(16):
            candidate = f".{target.name}.{secrets.token_hex(16)}.tmp"
            try:
                descriptor = os.open(
                    candidate,
                    temporary_flags,
                    0o600,
                    dir_fd=directory,
                )
            except FileExistsError:
                continue
            temporary_name = candidate
            break
        if temporary_name is None:
            raise OSError("unable to allocate private temporary artifact")

        os.fchmod(descriptor, 0o600)
        temporary_metadata = os.fstat(descriptor)
        temporary_identity = temporary_metadata.st_dev, temporary_metadata.st_ino
        body = canonical_bytes(value) + b"\n"
        offset = 0
        while offset < len(body):
            written = os.write(descriptor, body[offset:])
            if written <= 0 or written > len(body) - offset:
                raise OSError("short private artifact write")
            offset += written
        os.fsync(descriptor)
        os.close(descriptor)
        descriptor = -1
        _commit_private_artifact(
            directory,
            temporary_name,
            target.name,
            expected_identity,
        )
        temporary_name = None
        os.fsync(directory)
    except Exception:
        if descriptor >= 0:
            try:
                os.close(descriptor)
            except OSError:
                pass
        if temporary_name is not None:
            try:
                current_identity = _directory_entry_identity(directory, temporary_name)
                if current_identity == temporary_identity:
                    os.unlink(temporary_name, dir_fd=directory)
            except OSError:
                pass
        raise
    finally:
        os.close(directory)


def validate_command(args: argparse.Namespace) -> int:
    inventory = load_inventory(args.inventory)
    print(json.dumps({"inventory_digest": inventory.inventory_digest, "artifact_digest": inventory.artifact_digest}, sort_keys=True))
    return 0


def plan_command(args: argparse.Namespace) -> int:
    inventory = load_inventory(args.inventory)
    plan = build_plan(inventory, read_json(args.live_state), read_json(args.operations))
    output = Path(args.output) if args.output else Path(args.state_dir) / "plan.json"
    write_private(output, plan.to_dict())
    print(json.dumps({"plan": str(output), "plan_digest": plan.plan_digest}, sort_keys=True))
    return 0


def status_command(args: argparse.Namespace) -> int:
    inventory = load_inventory(args.inventory)
    live = read_json(args.live_state)
    if not isinstance(live, Mapping):
        raise ApplyError("live state must be an object")
    live_state = live.get("state", live.get("live_state", {}))
    if not isinstance(live_state, Mapping):
        raise ApplyError("live state mapping is invalid")
    plan = plan_from_dict(read_json(args.plan))
    verify_plan(plan)
    current_live_digest = digest(live_state)
    desired_agrees = (
        hmac.compare_digest(plan.inventory_digest, inventory.inventory_digest)
        and hmac.compare_digest(plan.artifact_digest, inventory.artifact_digest)
        and plan.target_endpoint == inventory_endpoint(inventory, plan.target_profile)
    )
    live_agrees = hmac.compare_digest(plan.live_state_digest, current_live_digest)
    print(json.dumps({"desired_agrees": desired_agrees, "live_agrees": live_agrees, "plan_agrees": True, "inventory_digest": inventory.inventory_digest, "artifact_digest": inventory.artifact_digest, "live_state_digest": current_live_digest, "plan_digest": plan.plan_digest}, sort_keys=True))
    return 0


def apply_command(args: argparse.Namespace) -> int:
    if ENVIRONMENT_NAME.fullmatch(args.token_env) is None:
        raise ApplyError("token environment locator is invalid")
    if not os.environ.get(args.token_env):
        raise ApplyError("data-plane token is unavailable")
    inventory = load_inventory(args.inventory)
    raw_plan = read_json(args.plan)
    mutation = isinstance(raw_plan, dict) and "base_plan" in raw_plan
    plan = mutation_plan_from_dict(raw_plan) if mutation else plan_from_dict(raw_plan)
    base_plan = plan.base_plan if mutation else plan
    if (
        not hmac.compare_digest(base_plan.inventory_digest, inventory.inventory_digest)
        or not hmac.compare_digest(base_plan.artifact_digest, inventory.artifact_digest)
        or base_plan.target_profile != args.profile
        or base_plan.target_endpoint
        != inventory_endpoint(inventory, base_plan.target_profile)
    ):
        raise ApplyError("plan does not match the selected inventory and profile")
    desired_artifacts: dict[str, Any] = {}
    for profile in inventory.profiles:
        payload = deep_thaw(profile.get("config", profile))
        desired_artifacts[digest(payload)] = payload
    for bank in inventory.banks:
        payload = deep_thaw(bank.get("config", bank))
        desired_artifacts[digest(payload)] = payload
        for collection in ("models", "directives"):
            for item in bank.get(collection, ()):
                value = deep_thaw(item)
                desired_artifacts[digest(value)] = value
    for provider in inventory.providers:
        for item in provider.get("models", ()):
            value = deep_thaw(item)
            desired_artifacts[digest(value)] = value

    def resolve_desired_artifact(action: Any) -> Any:
        artifact_digest = action.details.get("artifact_digest")
        if artifact_digest not in desired_artifacts:
            raise ApplyError("desired artifact is absent from the selected inventory")
        return deep_thaw(desired_artifacts[artifact_digest])

    def reserve_external_action(control: Mapping[str, Any]) -> None:
        reservation_id = digest({
            "plan_digest": control.get("plan_digest"),
            "action_id": control.get("action_id"),
            "action_kind": control.get("action_kind"),
        })
        marker = (
            Path(args.state_dir)
            / "external-action-reservations"
            / f"{reservation_id}.json"
        )
        try:
            write_private(
                marker,
                {
                    "schema_version": 1,
                    "status": "indeterminate",
                    "control": dict(control),
                },
                create_only=True,
            )
        except OSError:
            raise ApplyError(
                "external action is already reserved and requires reconciliation"
            ) from None

    data_plane = HttpAdapter(
        inventory=inventory,
        profile_id=args.profile,
        token_resolver=lambda: os.environ.get(args.token_env, ""),
        artifact_resolver=resolve_desired_artifact,
        external_action_reserver=reserve_external_action,
    )
    adapter: Any = data_plane
    completion_marker: Path | None = None
    proposal_log: str | None = None
    if mutation:
        archive_paths = getattr(args, "migration_archive", None) or []
        evidence_path = getattr(args, "restore_evidence", None)
        if not archive_paths or not evidence_path:
            raise ApplyError("mutation apply requires archives and disposable restore evidence")
        archives: dict[str, str] = {}
        for archive_value in archive_paths:
            archive = Path(archive_value)
            archives[_regular_file_digest(archive, "migration archive")] = str(archive)
        try:
            evidence_record = read_file_evidence(
                evidence_path, "disposable restore evidence"
            )
            assert evidence_record is not None
            restore_evidence = strict_json_loads(evidence_record[0])
        except (
            FileEvidenceError,
            StrictJsonError,
            UnicodeDecodeError,
            json.JSONDecodeError,
        ):
            raise ApplyError("disposable restore evidence is unavailable") from None
        if not isinstance(restore_evidence, dict):
            raise ApplyError("disposable restore evidence must be a digest-keyed object")
        required_archive_digests = {action.details["archive_digest"] for action in plan.actions}
        rollback_archive = getattr(args, "rollback_archive", None)
        required_evidence = required_archive_digests | {plan.rollback_archive_digest}
        if (
            not rollback_archive
            or not required_archive_digests <= set(archives)
            or not required_evidence <= set(restore_evidence)
        ):
            raise ApplyError("approved mutation archive or restore evidence does not match the plan")
        if _paths_overlap(rollback_archive, list(archives.values())):
            raise ApplyError("rollback archive must be distinct from every migration archive")
        admin_value = getattr(args, "admin_executable", None)
        if not isinstance(admin_value, str) or not Path(admin_value).is_absolute():
            raise ApplyError("mutation apply requires an absolute hindsight-admin executable")
        migration = dict(inventory.migration)
        artifact_dir = Path(
            migration.get("artifact_dir", migration.get("artifact_path"))
        )
        proposal_log = migration.get(
            "proposal_log", migration.get("proposal_path")
        )
        completion_marker = (
            Path(args.completion_marker)
            if args.completion_marker
            else artifact_dir / "distillation-complete.marker"
        )
        protected_apply_inputs = [
            *archives.values(),
            args.inventory,
            args.plan,
            evidence_path,
            admin_value,
            completion_marker,
            proposal_log,
        ]
        if _paths_overlap(rollback_archive, protected_apply_inputs):
            raise ApplyError(
                "rollback archive must be distinct from every apply input"
            )
        admin = AdminMigrationAdapter(
            admin_executable=admin_value,
            argv_factory=hindsight_admin_argv,
            runner=subprocess.run,
            environment={
                key: os.environ[key]
                for key in sorted(ADMIN_ENVIRONMENT_ALLOWLIST)
                if key in os.environ
            },
        )
        adapter = MigrationApplyAdapter(
            data_plane=data_plane, admin=admin, archives=archives,
            restore_evidence=restore_evidence,
            rollback_archive=str(Path(rollback_archive)),
            rollback_archive_digest=plan.rollback_archive_digest,
            rollback_restore_evidence_digest=plan.rollback_restore_evidence_digest,
            restore_lock_dir=str(Path(args.state_dir) / "migration-restore-locks"),
            archive_verifier=lambda path, expected: hmac.compare_digest(
                _regular_file_digest(path, "rollback archive"), expected,
            ),
        )
    try:
        rollback_bundle = create_rollback_bundle(plan, adapter)
    except MigrationAdapterError:
        raise ApplyError(
            "rollback archive creation or digest verification failed"
        ) from None
    gate: dict[str, Any] = {"rollback_bundle": rollback_bundle}
    if mutation:
        assert completion_marker is not None and proposal_log is not None
        gate["migration_gate"] = capture_migration_gate(
            completion_marker, proposal_log
        )
    result = apply_plan(plan, adapter, args.approval_digest, gate)
    print(
        json.dumps(
            {
                "activation_enabled": result.activation_enabled,
                "applied_action_ids": list(result.applied_action_ids),
                "reason": result.reason,
                "rollback_attempted": result.rollback_attempted,
                "rollback_succeeded": result.rollback_succeeded,
                "status": result.status,
            },
            sort_keys=True,
        )
    )
    return 0 if result.status == "applied" else 2


def migration_discover_command(args: argparse.Namespace) -> int:
    if not args.read_only:
        raise MigrationError("migration discovery requires --read-only")
    if ENVIRONMENT_NAME.fullmatch(args.token_env) is None:
        raise MigrationError("token environment locator is invalid")
    if not os.environ.get(args.token_env):
        raise MigrationError("data-plane token is unavailable")
    inventory = load_inventory(args.inventory)
    manifest = read_json(args.offline_package_manifest)
    private_catalog_digests = read_json(args.private_catalog_digests)
    adapter = HttpAdapter(
        inventory=inventory,
        profile_id=args.profile,
        token_resolver=lambda: os.environ.get(args.token_env, ""),
    )
    migration = dict(inventory.migration)
    artifact_dir = migration.get("artifact_dir", migration.get("artifact_path"))
    proposal_log = migration.get("proposal_log", migration.get("proposal_path"))
    timestamp = args.timestamp or datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    result = discover_migration_state(
        adapter,
        source_bank=BankRef(args.profile, args.source_bank),
        candidate_bank=BankRef(args.profile, args.candidate_bank),
        offline_package_manifest=manifest,
        approved_offline_package_digest=args.approved_offline_package_digest,
        migration_paths={
            "artifact_dir": artifact_dir,
            "completion_marker": args.completion_marker,
            "proposal_log": proposal_log,
        },
        retain_watermark_reader=lambda: read_json(args.retain_watermarks),
        private_catalog_digests=private_catalog_digests,
        timestamp=timestamp,
    )
    print(
        json.dumps(
            {
                "approved": False,
                "blockers": list(result.blockers),
                "complete": result.complete,
                "inventory_digest": result.inventory_digest,
                "run_dir": result.run_dir,
                "shadow_plan_digest": result.shadow_plan_digest,
            },
            sort_keys=True,
        )
    )
    return 0 if result.complete else 2


def _broker_paths(args: argparse.Namespace) -> tuple[Path, Path, Path]:
    requested_state = Path(args.state_dir).expanduser()
    requested_socket = Path(args.socket).expanduser()
    if not requested_state.is_absolute() or not requested_socket.is_absolute():
        raise BrokerError("BROKER_PATH_INVALID")
    try:
        state_dir = requested_state.resolve(strict=False)
        socket_path = requested_socket.resolve(strict=False)
    except (OSError, RuntimeError):
        raise BrokerError("BROKER_PATH_INVALID") from None
    if socket_path.parent != state_dir:
        raise BrokerError("BROKER_PATH_INVALID")
    if socket_path.name in {
        "broker.pid",
        "broker.lock",
        "broker.signing-key",
    }:
        raise BrokerError("BROKER_PATH_INVALID")
    return state_dir, socket_path, state_dir / "broker.pid"


def _bounded_broker_timeout(value: Any) -> float:
    if (
        type(value) not in (int, float)
        or not math.isfinite(value)
        or not 0 <= value <= 30
    ):
        raise BrokerError("BROKER_TIMEOUT_INVALID")
    return float(value)


def _broker_state_components(path: Path) -> tuple[str, ...]:
    if not hasattr(os, "O_DIRECTORY") or not hasattr(os, "O_NOFOLLOW"):
        raise BrokerError("BROKER_PATH_INVALID")
    absolute = Path(os.path.abspath(path))
    if sys.platform == "darwin" and len(absolute.parts) > 1:
        aliases = {
            "var": ("private", "var"),
            "tmp": ("private", "tmp"),
            "etc": ("private", "etc"),
        }
        replacement = aliases.get(absolute.parts[1])
        if replacement is not None:
            absolute = Path("/").joinpath(
                *replacement, *absolute.parts[2:]
            )
    return absolute.parts[1:]


def _validate_broker_state_directory(
    descriptor: int, *, final: bool
) -> None:
    metadata = os.fstat(descriptor)
    if not stat.S_ISDIR(metadata.st_mode):
        raise BrokerError("BROKER_PATH_INVALID")
    if metadata.st_uid not in {0, os.geteuid()}:
        raise BrokerError("BROKER_PATH_INVALID")
    mode = stat.S_IMODE(metadata.st_mode)
    if mode & 0o022 and not (
        metadata.st_uid == 0 and metadata.st_mode & stat.S_ISVTX
    ):
        raise BrokerError("BROKER_PATH_INVALID")
    if final and metadata.st_uid != os.geteuid():
        raise BrokerError("BROKER_PATH_INVALID")
    if final and mode != 0o700:
        raise BrokerError("BROKER_STATE_MODE_INVALID")


def _open_broker_state_directory(
    state_dir: Path, *, create: bool
) -> int | None:
    if not state_dir.is_absolute():
        raise BrokerError("BROKER_PATH_INVALID")
    flags = os.O_RDONLY | os.O_DIRECTORY | os.O_NOFOLLOW
    components = _broker_state_components(state_dir)
    try:
        descriptor = os.open("/", flags)
    except OSError as error:
        raise BrokerError("BROKER_PATH_INVALID") from error
    try:
        _validate_broker_state_directory(
            descriptor, final=not components
        )
        for index, component in enumerate(components):
            final = index == len(components) - 1
            try:
                child = os.open(component, flags, dir_fd=descriptor)
            except FileNotFoundError:
                if not create or not final:
                    if final and not create:
                        os.close(descriptor)
                        return None
                    raise BrokerError("BROKER_PATH_INVALID") from None
                try:
                    os.mkdir(component, 0o700, dir_fd=descriptor)
                except FileExistsError:
                    pass
                else:
                    os.fsync(descriptor)
                child = os.open(component, flags, dir_fd=descriptor)
            except OSError as error:
                raise BrokerError("BROKER_PATH_INVALID") from error
            try:
                _validate_broker_state_directory(child, final=final)
            except Exception:
                os.close(child)
                raise
            os.close(descriptor)
            descriptor = child
        return descriptor
    except Exception:
        os.close(descriptor)
        raise


@contextmanager
def _broker_lifecycle_lock(
    state_dir: Path, *, deadline: float | None = None
):
    directory = _open_broker_state_directory(state_dir, create=False)
    if directory is None:
        raise BrokerError("BROKER_PATH_INVALID")
    flags = os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW
    try:
        descriptor = os.open(
            "broker.lock", flags, 0o600, dir_fd=directory
        )
    except Exception:
        os.close(directory)
        raise
    try:
        metadata = os.fstat(descriptor)
        if (
            not stat.S_ISREG(metadata.st_mode)
            or metadata.st_uid != os.geteuid()
            or metadata.st_nlink != 1
        ):
            raise BrokerError("BROKER_LOCK_INVALID")
        os.fchmod(descriptor, 0o600)
        lock_identity = metadata.st_dev, metadata.st_ino
        try:
            current = os.stat("broker.lock", dir_fd=directory, follow_symlinks=False)
        except OSError as error:
            raise BrokerError("BROKER_LOCK_INVALID") from error
        if lock_identity != (current.st_dev, current.st_ino):
            raise BrokerError("BROKER_LOCK_INVALID")
        if deadline is None:
            fcntl.flock(descriptor, fcntl.LOCK_EX)
        else:
            while True:
                try:
                    fcntl.flock(
                        descriptor, fcntl.LOCK_EX | fcntl.LOCK_NB
                    )
                    break
                except BlockingIOError:
                    remaining = deadline - time.monotonic()
                    if remaining <= 0:
                        raise BrokerError("BROKER_STOP_TIMEOUT")
                    time.sleep(min(0.01, remaining))
        metadata = os.fstat(descriptor)
        try:
            current = os.stat("broker.lock", dir_fd=directory, follow_symlinks=False)
        except OSError as error:
            raise BrokerError("BROKER_LOCK_INVALID") from error
        if (
            not stat.S_ISREG(metadata.st_mode)
            or metadata.st_uid != os.geteuid()
            or metadata.st_nlink != 1
            or stat.S_IMODE(metadata.st_mode) != 0o600
            or lock_identity != (current.st_dev, current.st_ino)
        ):
            raise BrokerError("BROKER_LOCK_INVALID")
        yield directory
    finally:
        try:
            fcntl.flock(descriptor, fcntl.LOCK_UN)
        except OSError:
            pass
        os.close(descriptor)
        os.close(directory)


def _remove_broker_socket(socket_path: Path) -> None:
    try:
        metadata = socket_path.lstat()
    except FileNotFoundError:
        return
    if not stat.S_ISSOCK(metadata.st_mode):
        raise BrokerError("BROKER_PATH_INVALID")
    identity = metadata.st_dev, metadata.st_ino
    current = socket_path.lstat()
    if not stat.S_ISSOCK(current.st_mode) or identity != (current.st_dev, current.st_ino):
        raise BrokerError("BROKER_PATH_INVALID")
    socket_path.unlink()


def _remove_broker_socket_entry(directory: int, name: str) -> None:
    try:
        metadata = os.stat(name, dir_fd=directory, follow_symlinks=False)
    except FileNotFoundError:
        return
    if not stat.S_ISSOCK(metadata.st_mode):
        raise BrokerError("BROKER_PATH_INVALID")
    identity = metadata.st_dev, metadata.st_ino
    current = os.stat(name, dir_fd=directory, follow_symlinks=False)
    if identity != (current.st_dev, current.st_ino):
        raise BrokerError("BROKER_PATH_INVALID")
    os.unlink(name, dir_fd=directory)
    os.fsync(directory)


def _broker_state_directory_matches(state_dir: Path, directory: int) -> bool:
    try:
        current = _open_broker_state_directory(state_dir, create=False)
    except BrokerError:
        return False
    if current is None:
        return False
    try:
        expected = os.fstat(directory)
        observed = os.fstat(current)
        return (expected.st_dev, expected.st_ino) == (observed.st_dev, observed.st_ino)
    finally:
        os.close(current)


def _private_broker_state(state_dir: Path, *, create: bool = True) -> bool:
    descriptor = _open_broker_state_directory(state_dir, create=create)
    if descriptor is None:
        return False
    os.close(descriptor)
    return True


def _read_private_file(
    path: Path,
    code: str,
    *,
    minimum_bytes: int,
    maximum_bytes: int,
    missing_ok: bool = False,
) -> bytes | None:
    path = Path(path)
    if path.name in {"", ".", ".."}:
        raise BrokerError(code)
    try:
        directory = _open_broker_state_directory(
            path.parent, create=False
        )
    except BrokerError as error:
        raise BrokerError(code) from error
    if directory is None:
        if missing_ok:
            return None
        raise BrokerError(code)
    try:
        return _read_private_entry(
            directory,
            path.name,
            code,
            minimum_bytes=minimum_bytes,
            maximum_bytes=maximum_bytes,
            missing_ok=missing_ok,
        )
    finally:
        os.close(directory)


def _read_private_entry(
    directory: int,
    name: str,
    code: str,
    *,
    minimum_bytes: int,
    maximum_bytes: int,
    missing_ok: bool = False,
) -> bytes | None:
    try:
        descriptor = os.open(
            name,
            os.O_RDONLY | os.O_NOFOLLOW | getattr(os, "O_CLOEXEC", 0),
            dir_fd=directory,
        )
    except FileNotFoundError:
        if missing_ok:
            return None
        raise BrokerError(code) from None
    except OSError as error:
        raise BrokerError(code) from error
    try:
        metadata = os.fstat(descriptor)
        if (
            not stat.S_ISREG(metadata.st_mode)
            or metadata.st_uid != os.geteuid()
            or metadata.st_nlink != 1
            or stat.S_IMODE(metadata.st_mode) != 0o600
            or not minimum_bytes <= metadata.st_size <= maximum_bytes
        ):
            raise BrokerError(code)
        value = os.read(descriptor, maximum_bytes + 1)
    finally:
        os.close(descriptor)
    if len(value) != metadata.st_size:
        raise BrokerError(code)
    return value


def _read_private(path: Path, expected_bytes: int, code: str) -> bytes:
    value = _read_private_file(
        path,
        code,
        minimum_bytes=expected_bytes,
        maximum_bytes=expected_bytes,
    )
    assert value is not None
    return value


def _broker_signing_key(state_dir: Path) -> bytes:
    path = state_dir / "broker.signing-key"
    directory = _open_broker_state_directory(state_dir, create=False)
    if directory is None:
        raise BrokerError("SIGNING_KEY_INVALID")
    try:
        existing = _read_private_entry(
            directory,
            path.name,
            "SIGNING_KEY_INVALID",
            minimum_bytes=32,
            maximum_bytes=32,
            missing_ok=True,
        )
    except Exception:
        os.close(directory)
        raise
    if existing is not None:
        os.close(directory)
        return existing
    flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL | os.O_NOFOLLOW
    value = secrets.token_bytes(32)
    try:
        descriptor = os.open(
            path.name, flags, 0o600, dir_fd=directory
        )
    except FileExistsError:
        try:
            existing = _read_private_entry(
                directory,
                path.name,
                "SIGNING_KEY_INVALID",
                minimum_bytes=32,
                maximum_bytes=32,
            )
            assert existing is not None
            return existing
        finally:
            os.close(directory)
    except Exception:
        os.close(directory)
        raise
    try:
        identity = None
        metadata = os.fstat(descriptor)
        identity = metadata.st_dev, metadata.st_ino
        os.fchmod(descriptor, 0o600)
        if os.write(descriptor, value) != len(value):
            raise OSError("short signing-key write")
        os.fsync(descriptor)
    except Exception:
        os.close(descriptor)
        try:
            current = os.stat(
                path.name, dir_fd=directory, follow_symlinks=False
            )
            if identity == (current.st_dev, current.st_ino):
                os.unlink(path.name, dir_fd=directory)
        except OSError:
            pass
        os.close(directory)
        raise
    else:
        os.close(descriptor)
    try:
        os.fsync(directory)
    except Exception:
        try:
            current = os.stat(
                path.name, dir_fd=directory, follow_symlinks=False
            )
            if identity == (current.st_dev, current.st_ino):
                os.unlink(path.name, dir_fd=directory)
            os.fsync(directory)
        finally:
            os.close(directory)
        raise
    else:
        os.close(directory)
    return value


def _broker_peer_pid(connection: socket.socket) -> int | None:
    try:
        if sys.platform == "darwin":
            payload = connection.getsockopt(0, 0x002, 4)
            return struct.unpack("i", payload)[0]
        if sys.platform.startswith("linux"):
            payload = connection.getsockopt(
                socket.SOL_SOCKET, getattr(socket, "SO_PEERCRED", 17), 12
            )
            return struct.unpack("3i", payload)[0]
    except (OSError, struct.error):
        return None
    return None


def _broker_probe(
    socket_path: Path,
    timeout: float = 1.0,
    *,
    expected_pid: int | None = None,
) -> bool:
    try:
        metadata = socket_path.lstat()
        if not stat.S_ISSOCK(metadata.st_mode) or stat.S_IMODE(metadata.st_mode) != 0o600:
            return False
        connection = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        connection.settimeout(timeout)
        with connection:
            connection.connect(str(socket_path))
            if (
                expected_pid is not None
                and _broker_peer_pid(connection) != expected_pid
            ):
                return False
            connection.sendall(BROKER_REQUEST)
            response = connection.makefile("rb").readline(4097)
        value = json.loads(response)
        return value == BROKER_HEALTH_RESPONSE
    except (OSError, json.JSONDecodeError, UnicodeDecodeError):
        return False


def _parse_broker_pid(raw: bytes) -> BrokerProcessIdentity:
    if raw is None:
        return None
    try:
        text = raw.decode("ascii")
    except UnicodeDecodeError as error:
        raise BrokerError("BROKER_PID_INVALID") from error
    try:
        value = json.loads(text)
    except json.JSONDecodeError:
        try:
            legacy_pid = int(text)
        except ValueError as error:
            raise BrokerError("BROKER_PID_INVALID") from error
        if not 1 < legacy_pid <= MAX_SIGNAL_PID:
            raise BrokerError("BROKER_PID_INVALID")
        return BrokerProcessIdentity(legacy_pid, None)
    if type(value) is int:
        if not 1 < value <= MAX_SIGNAL_PID:
            raise BrokerError("BROKER_PID_INVALID")
        return BrokerProcessIdentity(value, None)
    if not isinstance(value, dict) or set(value) not in (
        {"pid", "start_time"},
        {"pid", "start_time", "shutdown_capability"},
        {"pid", "start_time", "shutdown_capability", "profile_set_digest"},
    ):
        raise BrokerError("BROKER_PID_INVALID")
    pid = value["pid"]
    start_time = value["start_time"]
    if type(pid) is not int or not 1 < pid <= MAX_SIGNAL_PID:
        raise BrokerError("BROKER_PID_INVALID")
    if (
        not isinstance(start_time, str)
        or not start_time
        or len(start_time) > 128
        or start_time != " ".join(start_time.split())
    ):
        raise BrokerError("BROKER_PID_INVALID")
    shutdown_capability = value.get("shutdown_capability")
    if shutdown_capability is not None and (
        not isinstance(shutdown_capability, str)
        or not 32 <= len(shutdown_capability.encode("utf-8")) <= 4096
        or any(character in shutdown_capability for character in "\r\n\0")
    ):
        raise BrokerError("BROKER_PID_INVALID")
    profile_set_digest = value.get("profile_set_digest")
    if profile_set_digest is not None and (
        not isinstance(profile_set_digest, str)
        or re.fullmatch(r"[0-9a-f]{64}", profile_set_digest) is None
    ):
        raise BrokerError("BROKER_PID_INVALID")
    return BrokerProcessIdentity(pid, start_time, shutdown_capability, profile_set_digest)


def _read_broker_pid_entry(directory: int, name: str) -> BrokerProcessIdentity | None:
    raw = _read_private_entry(
        directory, name, "BROKER_PID_INVALID",
        minimum_bytes=1, maximum_bytes=256, missing_ok=True,
    )
    return None if raw is None else _parse_broker_pid(raw)


def _read_broker_pid(path: Path) -> BrokerProcessIdentity | None:
    raw = _read_private_file(
        path, "BROKER_PID_INVALID", minimum_bytes=1,
        maximum_bytes=256, missing_ok=True,
    )
    return None if raw is None else _parse_broker_pid(raw)


def _process_running(pid: int) -> bool:
    if type(pid) is not int or not 1 < pid <= MAX_SIGNAL_PID:
        raise BrokerError("BROKER_PID_INVALID")
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def _process_start_time(pid: int) -> str | None:
    if sys.platform == "darwin":
        class ProcBsdInfo(ctypes.Structure):
            _fields_ = [
                ("pbi_flags", ctypes.c_uint32),
                ("pbi_status", ctypes.c_uint32),
                ("pbi_xstatus", ctypes.c_uint32),
                ("pbi_pid", ctypes.c_uint32),
                ("pbi_ppid", ctypes.c_uint32),
                ("pbi_uid", ctypes.c_uint32),
                ("pbi_gid", ctypes.c_uint32),
                ("pbi_ruid", ctypes.c_uint32),
                ("pbi_rgid", ctypes.c_uint32),
                ("pbi_svuid", ctypes.c_uint32),
                ("pbi_svgid", ctypes.c_uint32),
                ("pbi_rfu_1", ctypes.c_uint32),
                ("pbi_comm", ctypes.c_char * 16),
                ("pbi_name", ctypes.c_char * 32),
                ("pbi_nfiles", ctypes.c_uint32),
                ("pbi_pgid", ctypes.c_uint32),
                ("pbi_pjobc", ctypes.c_uint32),
                ("e_tdev", ctypes.c_uint32),
                ("e_tpgid", ctypes.c_uint32),
                ("pbi_nice", ctypes.c_int32),
                ("pbi_start_tvsec", ctypes.c_uint64),
                ("pbi_start_tvusec", ctypes.c_uint64),
            ]

        try:
            libproc = ctypes.CDLL("/usr/lib/libproc.dylib", use_errno=True)
            proc_pidinfo = libproc.proc_pidinfo
            proc_pidinfo.argtypes = [
                ctypes.c_int,
                ctypes.c_int,
                ctypes.c_uint64,
                ctypes.c_void_p,
                ctypes.c_int,
            ]
            proc_pidinfo.restype = ctypes.c_int
            info = ProcBsdInfo()
            result = proc_pidinfo(
                pid,
                3,  # PROC_PIDTBSDINFO
                0,
                ctypes.byref(info),
                ctypes.sizeof(info),
            )
        except (AttributeError, OSError):
            pass
        else:
            if result == ctypes.sizeof(info):
                return f"darwin:{info.pbi_start_tvsec}:{info.pbi_start_tvusec}"

    proc_stat = Path(f"/proc/{pid}/stat")
    try:
        raw_stat = proc_stat.read_text(encoding="ascii")
        fields = raw_stat.rsplit(")", 1)[1].split()
        start_ticks = fields[19]
    except (FileNotFoundError, IndexError, OSError, UnicodeDecodeError):
        pass
    else:
        return f"linux:{start_ticks}"

    try:
        result = subprocess.run(
            ["/bin/ps", "-o", "lstart=", "-p", str(pid)],
            check=False,
            capture_output=True,
            text=True,
            timeout=1.0,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if result.returncode != 0:
        return None
    value = " ".join(result.stdout.split())
    if not value or len(value) > 128:
        return None
    return value


def _process_identity_matches(identity: BrokerProcessIdentity) -> bool:
    if identity.start_time is None or not _process_running(identity.pid):
        return False
    current = _process_start_time(identity.pid)
    return current is not None and hmac.compare_digest(current, identity.start_time)


def _terminate_broker_process(
    identity: BrokerProcessIdentity,
    socket_path: Path,
    *,
    timeout_seconds: float,
) -> None:
    if identity.start_time is None:
        raise BrokerError("BROKER_PID_IDENTITY_INVALID")
    pidfd_open = getattr(os, "pidfd_open", None)
    pidfd_send_signal = getattr(signal, "pidfd_send_signal", None)
    if pidfd_open is not None and pidfd_send_signal is not None:
        try:
            descriptor = pidfd_open(identity.pid)
        except ProcessLookupError:
            return
        except OSError as error:
            raise BrokerError("BROKER_PID_IDENTITY_INVALID") from error
        try:
            if not _process_identity_matches(identity):
                if not _process_running(identity.pid):
                    return
                raise BrokerError("BROKER_PID_IDENTITY_INVALID")
            try:
                pidfd_send_signal(descriptor, signal.SIGTERM)
            except ProcessLookupError:
                return
            except OSError as error:
                raise BrokerError("BROKER_PID_IDENTITY_INVALID") from error
        finally:
            os.close(descriptor)
        return
    # Platforms without pidfds must fail closed unless a stable start identity
    # is available and remains equal across two immediately adjacent reads.
    first = _process_start_time(identity.pid)
    second = _process_start_time(identity.pid)
    if (
        first is None
        or second is None
        or not hmac.compare_digest(first, identity.start_time)
        or not hmac.compare_digest(second, identity.start_time)
    ):
        if not _process_running(identity.pid):
            return
        raise BrokerError("BROKER_PID_IDENTITY_INVALID")
    try:
        client = JsonRpcClient(
            socket_path,
            timeout_seconds=max(0.001, min(timeout_seconds, 30.0)),
        )
        # Revalidate the recorded start identity immediately before the
        # shutdown mutation; client setup must not open a PID-reuse window.
        current = _process_start_time(identity.pid)
        if (
            current is None
            or not hmac.compare_digest(current, identity.start_time)
        ):
            if not _process_running(identity.pid):
                return
            raise BrokerError("BROKER_PID_IDENTITY_INVALID")
        result = client.broker_shutdown(identity.shutdown_capability or "")
    except BrokerError as error:
        if error.code == "BROKER_PID_IDENTITY_INVALID":
            raise
        raise BrokerError("BROKER_SHUTDOWN_UNAVAILABLE") from error
    except OSError as error:
        raise BrokerError("BROKER_SHUTDOWN_UNAVAILABLE") from error
    if result != {"stopping": True}:
        raise BrokerError("BROKER_SHUTDOWN_UNAVAILABLE")


def _write_broker_pid(
    path: Path, shutdown_capability: str | None = None
) -> BrokerProcessIdentity:
    process_identity = BrokerProcessIdentity(
        os.getpid(), _process_start_time(os.getpid()), shutdown_capability
    )
    if process_identity.start_time is None:
        raise BrokerError("BROKER_PROCESS_IDENTITY_UNAVAILABLE")
    flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    descriptor = os.open(path, flags, 0o600)
    identity: tuple[int, int] | None = None
    try:
        metadata = os.fstat(descriptor)
        identity = (metadata.st_dev, metadata.st_ino)
        os.fchmod(descriptor, 0o600)
        value = canonical_bytes(
            {
                "pid": process_identity.pid,
                "start_time": process_identity.start_time,
                **({"shutdown_capability": shutdown_capability}
                   if shutdown_capability is not None else {}),
            }
        )
        offset = 0
        while offset < len(value):
            written = os.write(descriptor, value[offset:])
            if written <= 0 or written > len(value) - offset:
                raise OSError("short broker PID write")
            offset += written
        os.fsync(descriptor)
    except Exception:
        try:
            os.close(descriptor)
        except OSError:
            pass
        try:
            metadata = path.lstat()
            if identity is not None and identity == (metadata.st_dev, metadata.st_ino):
                path.unlink()
        except OSError:
            pass
        raise
    else:
        os.close(descriptor)
    return process_identity


def _write_broker_pid_entry(
    directory: int, name: str, shutdown_capability: str, profile_set_digest: str
) -> BrokerProcessIdentity:
    process_identity = BrokerProcessIdentity(
        os.getpid(), _process_start_time(os.getpid()), shutdown_capability,
        profile_set_digest,
    )
    if process_identity.start_time is None:
        raise BrokerError("BROKER_PROCESS_IDENTITY_UNAVAILABLE")
    flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL | os.O_NOFOLLOW
    descriptor = os.open(name, flags, 0o600, dir_fd=directory)
    identity: tuple[int, int] | None = None
    try:
        metadata = os.fstat(descriptor)
        identity = metadata.st_dev, metadata.st_ino
        os.fchmod(descriptor, 0o600)
        value = canonical_bytes(
            {
                "pid": process_identity.pid,
                "start_time": process_identity.start_time,
                "shutdown_capability": shutdown_capability,
                "profile_set_digest": profile_set_digest,
            }
        )
        offset = 0
        while offset < len(value):
            written = os.write(descriptor, value[offset:])
            if written <= 0:
                raise OSError("short broker PID write")
            offset += written
        os.fsync(descriptor)
        os.fsync(directory)
    except Exception:
        try:
            current = os.stat(name, dir_fd=directory, follow_symlinks=False)
            if identity == (current.st_dev, current.st_ino):
                os.unlink(name, dir_fd=directory)
                os.fsync(directory)
        except OSError:
            pass
        raise
    finally:
        os.close(descriptor)
    return process_identity


def _broker_environment_resolver(name: str, label: str):
    if not isinstance(name, str) or ENVIRONMENT_NAME.fullmatch(name) is None:
        raise BrokerError(f"BROKER_{label}_RESOLVER_INVALID")

    def resolve() -> str:
        value = os.environ.get(name)
        if (
            not isinstance(value, str)
            or not value
            or "\r" in value
            or "\n" in value
        ):
            raise BrokerError(f"BROKER_{label}_UNAVAILABLE")
        return value

    return resolve


def _broker_runtime_configuration(
    args: argparse.Namespace, *, preflight_resolvers: bool = True
):
    try:
        inventory = load_inventory(args.inventory)
        token_resolver = _broker_environment_resolver(
            args.data_plane_token_env, "DATA_PLANE_TOKEN"
        )
        mint_authority_resolver = _broker_environment_resolver(
            args.mint_authority_env, "MINT_AUTHORITY"
        )
        # Fail closed before creating the socket or PID record. Resolvers remain
        # lazy afterward so rotation does not require broker reconstruction.
        if preflight_resolvers:
            token_value = token_resolver()
            mint_authority_value = mint_authority_resolver()
            if hmac.compare_digest(
                token_value.encode("utf-8"),
                mint_authority_value.encode("utf-8"),
            ):
                raise BrokerError(
                    "BROKER_RUNTIME_CREDENTIAL_SEPARATION_INVALID"
                )
        return compile_runtime_configuration(
            inventory=inventory,
            profiles=tuple(args.profile),
            token_resolver=token_resolver,
            mint_authority_resolver=mint_authority_resolver,
            token_resolver_id=args.data_plane_token_env,
            mint_authority_resolver_id=args.mint_authority_env,
            verify_adapters=preflight_resolvers,
        )
    except (InventoryError, RuntimeConfigurationError, AdapterError) as error:
        raise BrokerError("BROKER_RUNTIME_CONFIGURATION_INVALID") from error


def _broker_binding_mode_error(
    inactive: bool, bindings: tuple[Any, Any, Any]
) -> str | None:
    if inactive and any(bindings):
        return "inactive-with-bindings"
    if not inactive and not all(bindings):
        return "active-missing-bindings"
    return None


def _broker_runtime_bindings(args: argparse.Namespace):
    # Command functions are also a tested programmatic interface. Older
    # callers construct a minimal Namespace without the parser's runtime
    # fields; keep that explicit transitional shape inactive.
    inactive = getattr(args, "inactive", True)
    bindings = (
        getattr(args, "inventory", None),
        getattr(args, "data_plane_token_env", None),
        getattr(args, "mint_authority_env", None),
    )
    binding_error = _broker_binding_mode_error(inactive, bindings)
    if binding_error == "inactive-with-bindings":
        raise BrokerError("BROKER_RUNTIME_CONFIGURATION_INVALID")
    if inactive:
        return None
    if binding_error == "active-missing-bindings":
        raise BrokerError("BROKER_RUNTIME_CONFIGURATION_REQUIRED")
    return bindings


def _broker_selected_runtime(
    args: argparse.Namespace, *, preflight_resolvers: bool
):
    if _broker_runtime_bindings(args) is None:
        return None
    return _broker_runtime_configuration(
        args, preflight_resolvers=preflight_resolvers
    )


def _broker_selected_runtime_status(args: argparse.Namespace):
    if _broker_runtime_bindings(args) is None:
        return None
    try:
        inventory = load_inventory(args.inventory)
        return compile_runtime_status(
            inventory=inventory,
            profiles=tuple(args.profile),
            token_resolver_id=args.data_plane_token_env,
            mint_authority_resolver_id=args.mint_authority_env,
        )
    except (InventoryError, RuntimeConfigurationError) as error:
        raise BrokerError("BROKER_RUNTIME_CONFIGURATION_INVALID") from error


def _inactive_broker_policy_digest(profiles: list[str]) -> str:
    return digest({
        "mode": "inactive", "profiles": sorted(set(profiles)),
    })


def broker_serve_command(args: argparse.Namespace) -> int:
    shutdown_timeout = _bounded_broker_timeout(args.shutdown_timeout)
    state_dir, socket_path, pid_path = _broker_paths(args)
    _private_broker_state(state_dir)
    key: bytes | None = None
    runtime = _broker_selected_runtime(args, preflight_resolvers=True)
    policy_digest = (
        runtime.policy_digest
        if runtime is not None
        else _inactive_broker_policy_digest(args.profile)
    )
    artifact_digest = (
        runtime.artifact_digest
        if runtime is not None
        else digest({"broker_schema_version": 1, "routes": []})
    )
    process_digest = (
        runtime.profile_set_digest if runtime is not None else policy_digest
    )
    stopped = threading.Event()
    shutdown_capability = secrets.token_urlsafe(32)

    def stop(_signum: int, _frame: Any) -> None:
        stopped.set()

    previous = {signum: signal.signal(signum, stop) for signum in (signal.SIGINT, signal.SIGTERM)}
    broker_identity: BrokerProcessIdentity | None = None
    broker: Broker | None = None
    server: UnixJsonRpcServer | None = None
    shutdown = {
        "undrained": 0,
        "active_reads": 0,
        "active_writes": 0,
        "retired": False,
        "retirement_pending": False,
    }
    try:
        with _broker_lifecycle_lock(state_dir) as directory:
            if not _broker_state_directory_matches(state_dir, directory):
                raise BrokerError("BROKER_PATH_INVALID")
            key = _broker_signing_key(state_dir)
            if not _broker_state_directory_matches(state_dir, directory):
                raise BrokerError("BROKER_PATH_INVALID")
            existing_identity = _read_broker_pid_entry(directory, pid_path.name)
            if existing_identity is not None:
                if _process_running(existing_identity.pid):
                    if _process_identity_matches(existing_identity):
                        raise BrokerError("BROKER_ALREADY_RUNNING")
                    if _process_running(existing_identity.pid):
                        raise BrokerError("BROKER_PID_IDENTITY_INVALID")
                if _read_broker_pid_entry(directory, pid_path.name) == existing_identity:
                    if _process_running(existing_identity.pid):
                        if _process_identity_matches(existing_identity):
                            raise BrokerError("BROKER_ALREADY_RUNNING")
                        raise BrokerError("BROKER_PID_IDENTITY_INVALID")
                    os.unlink(pid_path.name, dir_fd=directory)
                    os.fsync(directory)
            if socket_path.exists() or socket_path.is_symlink():
                if not _broker_state_directory_matches(state_dir, directory):
                    raise BrokerError("BROKER_PATH_INVALID")
                if _broker_probe(socket_path):
                    raise BrokerError("BROKER_ALREADY_RUNNING")
                if _broker_probe(socket_path):
                    raise BrokerError("BROKER_ALREADY_RUNNING")
                _remove_broker_socket_entry(directory, socket_path.name)
            assert key is not None
            broker = Broker(
                state_dir=state_dir,
                signing_key=key,
                routes=runtime.routes if runtime is not None else {},
                policy_digest=policy_digest,
                artifact_digest=artifact_digest,
                mint_authorizer=(
                    runtime.mint_authorizer
                    if runtime is not None
                    else lambda _control, _claims, _ttl: {}
                ),
            )
            server = UnixJsonRpcServer(
                socket_path,
                broker,
                shutdown_callback=stopped.set,
                shutdown_capability=shutdown_capability,
            )
            if not _broker_state_directory_matches(state_dir, directory):
                raise BrokerError("BROKER_PATH_INVALID")
            server.start()
            if not _broker_state_directory_matches(state_dir, directory):
                server.close()
                raise BrokerError("BROKER_PATH_INVALID")
            broker_identity = _write_broker_pid_entry(
                directory, pid_path.name, shutdown_capability, process_digest
            )
        ready = (
            {"broker": "ready", **dict(runtime.status)}
            if runtime is not None
            else {
                "broker": "ready", "mode": "inactive",
                "profiles": sorted(set(args.profile)),
            }
        )
        print(json.dumps(ready, sort_keys=True), flush=True)
        while not stopped.wait(0.25):
            pass
    finally:
        with _broker_lifecycle_lock(state_dir) as directory:
            close_error: Exception | None = None
            shutdown_error: Exception | None = None
            if server is not None:
                try:
                    server.close()
                except Exception as error:
                    close_error = (
                        error
                        if isinstance(error, BrokerError)
                        else BrokerError("BROKER_SERVER_CLOSE_FAILED")
                    )
            if broker is not None:
                try:
                    shutdown = broker.shutdown(
                        timeout_seconds=shutdown_timeout
                    )
                except Exception as error:
                    shutdown_error = error
        for signum, handler in previous.items():
            signal.signal(signum, handler)
        if close_error is not None:
            raise close_error
        if shutdown_error is not None:
            raise shutdown_error
    if (
        shutdown["undrained"]
        or shutdown["active_reads"]
        or shutdown["active_writes"]
        or shutdown["retirement_pending"]
    ):
        raise BrokerError("BROKER_SHUTDOWN_INCOMPLETE")
    try:
        with _broker_lifecycle_lock(state_dir) as directory:
            if (
                broker_identity is not None
                and _read_broker_pid_entry(directory, pid_path.name) == broker_identity
            ):
                os.unlink(pid_path.name, dir_fd=directory)
                os.fsync(directory)
    except BrokerError:
        raise
    except Exception as error:
        raise BrokerError("BROKER_PID_CLEANUP_FAILED") from error
    return 0


def broker_status_command(args: argparse.Namespace) -> int:
    state_dir, socket_path, pid_path = _broker_paths(args)
    if not _private_broker_state(state_dir, create=False):
        raise BrokerError("BROKER_UNAVAILABLE")
    runtime_status = _broker_selected_runtime_status(args)
    expected_profile_set_digest = (
        runtime_status["profile_set_digest"]
        if runtime_status is not None
        else _inactive_broker_policy_digest(args.profile)
    )
    identity = _read_broker_pid(pid_path)
    if identity is None:
        raise BrokerError("BROKER_UNAVAILABLE")
    if not hmac.compare_digest(
        identity.profile_set_digest or "", expected_profile_set_digest
    ):
        raise BrokerError("BROKER_PROFILE_SET_MISMATCH")
    if (
        not _process_identity_matches(identity)
        or not _broker_probe(socket_path, expected_pid=identity.pid)
        or _read_broker_pid(pid_path) != identity
        or not _process_identity_matches(identity)
    ):
        raise BrokerError("BROKER_UNAVAILABLE")
    status = (
        {
            "broker": "healthy", "socket": str(socket_path),
            **dict(runtime_status),
        }
        if runtime_status is not None
        else {"broker": "healthy", "mode": "inactive", "socket": str(socket_path)}
    )
    print(json.dumps(status, sort_keys=True))
    return 0


def broker_stop_command(args: argparse.Namespace) -> int:
    timeout = _bounded_broker_timeout(args.timeout)
    deadline = time.monotonic() + timeout
    state_dir, socket_path, pid_path = _broker_paths(args)
    if not _private_broker_state(state_dir, create=False):
        return 0
    with _broker_lifecycle_lock(state_dir, deadline=deadline) as directory:
        if not _broker_state_directory_matches(state_dir, directory):
            raise BrokerError("BROKER_PATH_INVALID")
        identity = _read_broker_pid_entry(directory, pid_path.name)
        if identity is None:
            if _broker_probe(socket_path):
                raise BrokerError("BROKER_PID_INVALID")
            if _broker_probe(socket_path):
                raise BrokerError("BROKER_PID_INVALID")
            _remove_broker_socket_entry(directory, socket_path.name)
            return 0
        if _process_running(identity.pid):
            if _process_identity_matches(identity):
                _terminate_broker_process(
                    identity,
                    socket_path,
                    timeout_seconds=max(0.001, deadline - time.monotonic()),
                )
            elif _process_running(identity.pid):
                raise BrokerError("BROKER_PID_IDENTITY_INVALID")
    while True:
        remaining = max(0.0, deadline - time.monotonic())
        probe_timeout = min(0.1, max(0.001, remaining))
        if not _process_identity_matches(identity) and not _broker_probe(
            socket_path,
            timeout=probe_timeout,
            expected_pid=identity.pid,
        ):
            with _broker_lifecycle_lock(state_dir, deadline=deadline) as directory:
                if not _broker_state_directory_matches(state_dir, directory):
                    raise BrokerError("BROKER_PATH_INVALID")
                if _process_identity_matches(identity) or _broker_probe(
                    socket_path,
                    timeout=probe_timeout,
                    expected_pid=identity.pid,
                ):
                    continue
                current_identity = _read_broker_pid_entry(directory, pid_path.name)
                if current_identity == identity:
                    if _broker_probe(socket_path, timeout=probe_timeout):
                        raise BrokerError("BROKER_PID_INVALID")
                    _remove_broker_socket_entry(directory, socket_path.name)
                    os.unlink(pid_path.name, dir_fd=directory)
                    os.fsync(directory)
                return 0
        if time.monotonic() >= deadline:
            break
        time.sleep(min(0.05, max(0.0, deadline - time.monotonic())))
    raise BrokerError("BROKER_STOP_TIMEOUT")


def _required_environment(name: str, code: str) -> str:
    if not isinstance(name, str) or ENVIRONMENT_NAME.fullmatch(name) is None:
        raise BrokerError(code)
    value = os.environ.get(name)
    if not value:
        raise BrokerError(code)
    return value


def _request_object(path: str, label: str) -> dict[str, Any]:
    value = read_json(path)
    if not isinstance(value, dict):
        raise BrokerError(f"{label}_INVALID")
    return value


def _print_result(value: Any) -> int:
    if not isinstance(value, dict):
        raise BrokerError("RESPONSE_INVALID")
    print(json.dumps(value, sort_keys=True, separators=(",", ":")))
    return 0


def _json_rpc_client(args: argparse.Namespace) -> JsonRpcClient:
    state_dir, socket_path, pid_path = _broker_paths(args)
    timeout = _bounded_broker_timeout(args.timeout)
    deadline = time.monotonic() + timeout
    if not _private_broker_state(state_dir, create=False):
        raise BrokerError("BROKER_UNAVAILABLE")
    with _broker_lifecycle_lock(state_dir, deadline=deadline) as directory:
        if not _broker_state_directory_matches(state_dir, directory):
            raise BrokerError("BROKER_PATH_INVALID")
        identity = _read_broker_pid_entry(directory, pid_path.name)
        if (
            identity is None
            or not _process_identity_matches(identity)
            or not _broker_probe(
                socket_path,
                timeout=max(0.001, deadline - time.monotonic()),
                expected_pid=identity.pid,
            )
            or _read_broker_pid_entry(directory, pid_path.name) != identity
            or not _process_identity_matches(identity)
        ):
            raise BrokerError("BROKER_PID_IDENTITY_INVALID")
        return JsonRpcClient(socket_path, timeout_seconds=timeout)


def session_mint_command(args: argparse.Namespace) -> int:
    return _print_result(
        _json_rpc_client(args).session_mint(
            _required_environment(
                args.control_capability_env, "CONTROL_CAPABILITY_UNAVAILABLE"
            ),
            _request_object(args.request, "MINT_REQUEST"),
            ttl_seconds=args.ttl_seconds,
        )
    )


def session_exchange_command(args: argparse.Namespace) -> int:
    return _print_result(
        _json_rpc_client(args).session_exchange(
            _required_environment(args.handle_env, "SESSION_HANDLE_UNAVAILABLE")
        )
    )


def _session_capability(args: argparse.Namespace) -> str:
    return _required_environment(
        args.capability_env, "SESSION_CAPABILITY_UNAVAILABLE"
    )


def session_close_command(args: argparse.Namespace) -> int:
    return _print_result(
        _json_rpc_client(args).session_close(
            _session_capability(args),
            sequence=args.sequence,
            action_id=args.action_id,
            timeout_seconds=args.timeout,
        )
    )


def broker_method_command(args: argparse.Namespace) -> int:
    client = _json_rpc_client(args)
    capability = _session_capability(args)
    method = args.rpc_method
    common = {
        "sequence": args.sequence,
        "action_id": args.action_id,
    }
    if method == "session_status":
        result = client.session_status(
            capability, timeout_seconds=args.timeout, **common
        )
    else:
        request = _request_object(args.request, "REQUEST")
        target = getattr(client, method)
        if method in {"recall", "mental_model_fetch", "reflect"}:
            result = target(
                capability, request=request, timeout_seconds=args.timeout, **common
            )
        else:
            result = target(capability, request=request, **common)
    return _print_result(result)


def _add_socket(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--socket", required=True)
    parser.add_argument("--timeout", type=_argparse_timeout, default=2.0)


def _argparse_timeout(value: str) -> float:
    try:
        timeout = float(value)
    except (TypeError, ValueError):
        raise argparse.ArgumentTypeError("BROKER_TIMEOUT_INVALID") from None
    if not math.isfinite(timeout) or not 0 <= timeout <= 30:
        raise argparse.ArgumentTypeError("BROKER_TIMEOUT_INVALID")
    return timeout


def _add_session_request(
    parser: argparse.ArgumentParser,
    *,
    rpc_method: str,
    request: bool = True,
) -> None:
    _add_socket(parser)
    parser.add_argument(
        "--capability-env", default="HINDSIGHT_MEMORY_SESSION_CAPABILITY"
    )
    parser.add_argument("--sequence", type=int, required=True)
    parser.add_argument("--action-id", required=True)
    if request:
        parser.add_argument("--request", required=True)
    parser.set_defaults(run=broker_method_command, rpc_method=rpc_method)


def parser() -> argparse.ArgumentParser:
    value = argparse.ArgumentParser(prog="hindsight-memory")
    value.add_argument("--state-dir", required=True)
    commands = value.add_subparsers(dest="command", required=True)

    validate = commands.add_parser("validate")
    validate.add_argument("--inventory", required=True)
    validate.set_defaults(run=validate_command)

    plan = commands.add_parser("plan")
    plan.add_argument("--inventory", required=True)
    plan.add_argument("--live-state", required=True)
    plan.add_argument("--operations", required=True)
    plan.add_argument("--output")
    plan.set_defaults(run=plan_command)

    status = commands.add_parser("status")
    status.add_argument("--inventory", required=True)
    status.add_argument("--live-state", required=True)
    status.add_argument("--plan", required=True)
    status.set_defaults(run=status_command)

    apply = commands.add_parser("apply")
    apply.add_argument("--inventory", required=True)
    apply.add_argument("--profile", required=True)
    apply.add_argument("--plan", required=True)
    apply.add_argument("--approval-digest", required=True)
    apply.add_argument("--token-env", required=True)
    apply.add_argument("--completion-marker")
    apply.add_argument("--migration-archive", action="append")
    apply.add_argument("--restore-evidence")
    apply.add_argument("--rollback-archive")
    apply.add_argument("--admin-executable")
    apply.set_defaults(run=apply_command)

    migration = commands.add_parser("migration")
    migration_commands = migration.add_subparsers(dest="migration_command", required=True)
    discover = migration_commands.add_parser("discover")
    discover.add_argument("--read-only", action="store_true", required=True)
    discover.add_argument("--inventory", required=True)
    discover.add_argument("--profile", required=True)
    discover.add_argument("--source-bank", required=True)
    discover.add_argument("--candidate-bank", required=True)
    discover.add_argument("--offline-package-manifest", required=True)
    discover.add_argument("--approved-offline-package-digest", required=True)
    discover.add_argument("--private-catalog-digests", required=True)
    discover.add_argument("--retain-watermarks", required=True)
    discover.add_argument("--completion-marker", required=True)
    discover.add_argument("--token-env", required=True)
    discover.add_argument("--timestamp", help=argparse.SUPPRESS)
    discover.set_defaults(run=migration_discover_command)

    broker = commands.add_parser("broker")
    broker_commands = broker.add_subparsers(dest="broker_command", required=True)
    serve = broker_commands.add_parser("serve")
    serve.add_argument("--socket", required=True)
    serve.add_argument("--profile", action="append", required=True)
    serve.add_argument("--inactive", action="store_true")
    serve.add_argument("--inventory")
    serve.add_argument("--data-plane-token-env")
    serve.add_argument("--mint-authority-env")
    serve.add_argument("--shutdown-timeout", type=_argparse_timeout, default=5.0)
    serve.set_defaults(run=broker_serve_command)
    broker_status = broker_commands.add_parser("status")
    broker_status.add_argument("--socket", required=True)
    broker_status.add_argument("--profile", action="append", required=True)
    broker_status.add_argument("--inactive", action="store_true")
    broker_status.add_argument("--inventory")
    broker_status.add_argument("--data-plane-token-env")
    broker_status.add_argument("--mint-authority-env")
    broker_status.set_defaults(run=broker_status_command)
    broker_stop = broker_commands.add_parser("stop")
    broker_stop.add_argument("--socket", required=True)
    broker_stop.add_argument("--timeout", type=_argparse_timeout, default=5.0)
    broker_stop.set_defaults(run=broker_stop_command)

    session = commands.add_parser("session")
    session_commands = session.add_subparsers(dest="session_command", required=True)
    mint = session_commands.add_parser("mint")
    _add_socket(mint)
    mint.add_argument(
        "--control-capability-env",
        default="HINDSIGHT_MEMORY_CONTROL_CAPABILITY",
    )
    mint.add_argument("--request", required=True)
    mint.add_argument("--ttl-seconds", type=float, default=60.0)
    mint.set_defaults(run=session_mint_command)
    exchange = session_commands.add_parser("exchange")
    _add_socket(exchange)
    exchange.add_argument(
        "--handle-env", default="HINDSIGHT_MEMORY_SESSION_HANDLE"
    )
    exchange.set_defaults(run=session_exchange_command)
    close = session_commands.add_parser("close")
    _add_socket(close)
    close.add_argument(
        "--capability-env", default="HINDSIGHT_MEMORY_SESSION_CAPABILITY"
    )
    close.add_argument("--sequence", type=int, required=True)
    close.add_argument("--action-id", required=True)
    close.set_defaults(run=session_close_command)

    for name, rpc_method, needs_request in (
        ("recall", "recall", True),
        ("mental_model_fetch", "mental_model_fetch", True),
        ("checkpoint", "transcript_checkpoint", True),
        ("retain_outcome", "retain_outcome", True),
        ("reflect", "reflect", True),
        ("session_status", "session_status", False),
    ):
        method = commands.add_parser(name)
        _add_session_request(
            method, rpc_method=rpc_method, request=needs_request
        )
    return value


def _validate_broker_binding_arguments(
    argument_parser: argparse.ArgumentParser, args: argparse.Namespace
) -> None:
    if (
        getattr(args, "command", None) != "broker"
        or getattr(args, "broker_command", None) not in {"serve", "status"}
    ):
        return
    bindings = (
        args.inventory, args.data_plane_token_env, args.mint_authority_env,
    )
    binding_error = _broker_binding_mode_error(args.inactive, bindings)
    if binding_error == "inactive-with-bindings":
        argument_parser.error(
            "--inactive cannot be combined with runtime bindings"
        )
    if binding_error == "active-missing-bindings":
        argument_parser.error(
            "active broker mode requires --inventory, "
            "--data-plane-token-env, and --mint-authority-env"
        )


def main() -> int:
    try:
        argument_parser = parser()
        args = argument_parser.parse_args()
        _validate_broker_binding_arguments(argument_parser, args)
        return args.run(args)
    except (
        AdapterError,
        ApplyError,
        BrokerError,
        InventoryError,
        MigrationAdapterError,
        MigrationError,
        PlanError,
        StrictJsonError,
        UnicodeDecodeError,
        OSError,
        json.JSONDecodeError,
    ) as error:
        print(f"hindsight-memory: {error}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
