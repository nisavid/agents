{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:nisavid:agents:hindsight-memory:benchmark-case:v1",
  "title": "Hindsight Memory Retrieval Benchmark Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "query",
    "relevance",
    "must_recall",
    "must_not_return"
  ],
  "$comment": "This schema describes one record only. The executable load_cases validator is authoritative for all cross-field and cross-record invariants.",
  "properties": {
    "schema_version": {"const": 1},
    "case_id": {"type": "string", "pattern": ".*\\S.*"},
    "query": {"type": "string", "pattern": ".*\\S.*"},
    "relevance": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {"pattern": ".*\\S.*"},
      "additionalProperties": {"type": "integer", "minimum": 1, "maximum": 3}
    },
    "must_recall": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": ".*\\S.*"}
    },
    "must_not_return": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": ".*\\S.*"}
    }
  }
}
